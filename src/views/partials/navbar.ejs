<nav class="navbar navbar-expand-lg sticky-top" id="mainNavbar">
    <div class="container">
        <!-- Brand -->
        <a class="navbar-brand" href="/">
            <img src="/images/logo_haianh_2.png" alt="Hải Anh Fruit" class="logo-main">
        </a>

        <!-- Mobile Toggle -->
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <!-- Nav links - Dynamic Categories -->
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-4">
                <li class="nav-item">
                    <a class="nav-link <%= req.originalUrl === '/' ? 'active' : '' %>" href="/">Trang chủ</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle <%= req.originalUrl.startsWith('/products') ? 'active' : '' %>" href="/products" role="button" data-bs-toggle="dropdown">
                        Sản phẩm
                    </a>
                    <ul class="dropdown-menu border-0 shadow-sm mt-2 rounded-4 py-2">
                        <li><a class="dropdown-item" href="/products">Tất cả sản phẩm</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <% if (typeof globalCategories !== 'undefined') { %>
                            <% globalCategories.forEach(cat => { %>
                                <li>
                                    <a class="dropdown-item" href="/products?category=<%= cat.slug %>">
                                        <%= cat.name %>
                                    </a>
                                </li>
                            <% }) %>
                        <% } %>
                    </ul>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/blog">Kiến thức</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= req.originalUrl === '/contact' ? 'active' : '' %>" href="/contact">Liên hệ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= req.originalUrl === '/track-order' ? 'active' : '' %>" href="/track-order">Tra cứu</a>
                </li>
            </ul>

            <!-- Right Side -->
            <div class="d-flex align-items-center gap-3">
                <!-- Search -->
                <form action="/products" method="GET" class="d-none d-lg-flex">
                    <div class="search-bar">
                        <input type="text" name="q" class="form-control rounded-pill border-0 bg-light ps-4 pe-5" 
                               placeholder="Tìm sản phẩm..." value="<%= typeof filters !== 'undefined' && filters.search ? filters.search : '' %>">
                        <button type="submit" class="search-btn">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Cart -->
                <a href="/cart" class="nav-icon-btn position-relative" title="Giỏ hàng">
                    <i class="fas fa-shopping-basket"></i>
                    <span class="cart-badge" id="nav-cart-badge"><%= typeof cartItemsCount !== 'undefined' ? cartItemsCount : 0 %></span>
                </a>

                <!-- User Account -->
                <% if (user) { %>
                    <div class="dropdown">
                        <button class="btn btn-outline-primary btn-sm rounded-pill px-3 dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle me-1"></i> <%= user.full_name.split(' ').pop() %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm mt-2 rounded-4">
                            <li><a class="dropdown-item" href="/profile"><i class="fas fa-address-card me-2 text-muted"></i>Hồ sơ</a></li>
                            <li><a class="dropdown-item" href="/wishlist"><i class="fas fa-heart me-2 text-danger"></i>Yêu thích</a></li>
                            <li><a class="dropdown-item" href="/orders"><i class="fas fa-box me-2 text-muted"></i>Đơn hàng</a></li>
                            <% if (user.role === 'admin') { %>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/admin"><i class="fas fa-shield-alt me-2"></i>Admin</a></li>
                            <% } %>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form action="/auth/logout" method="POST">
                                    <button type="submit" class="dropdown-item text-muted">
                                        <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-primary btn-sm rounded-pill px-4">Đăng nhập</a>
                <% } %>
            </div>
        </div>
    </div>
</nav>

<style>
.search-bar {
    position: relative;
    width: 240px;
}
.search-bar .form-control {
    height: 38px;
    font-size: 0.875rem;
}
.search-btn {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
}
.nav-icon-btn {
    color: var(--text-main);
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    padding: 6px;
}
.nav-icon-btn:hover { color: var(--brand-accent); }
.cart-badge {
    position: absolute;
    top: -4px;
    right: -6px;
    background: #e53e3e;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}
.dropdown-menu { min-width: 200px; }
.dropdown-item { padding: 8px 20px; font-size: 0.9rem; }
.dropdown-item:hover { background: var(--brand-light-green); color: var(--brand-primary); }
</style>
