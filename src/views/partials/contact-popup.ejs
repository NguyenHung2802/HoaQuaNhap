<!-- Floating Contact Widget -->
<div class="floating-chat-container">
    <div id="contactPopup" class="contact-popup-window shadow-lg d-none">
        <div class="contact-popup-header text-white p-3 d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #1b5e20, #2e7d32);">
            <div class="d-flex align-items-center gap-2">
                <div class="header-avatar bg-white rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; color: #1b5e20;">
                    <i class="fas fa-phone-alt" style="font-size: 1rem;"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold" style="font-size: 1rem;">Yêu cầu gọi lại</h6>
                    <small style="font-size: 0.8rem; opacity: 0.9;">Chuyên viên liên hệ trong 5 phút!</small>
                </div>
            </div>
            <button type="button" class="btn btn-sm text-white p-0 border-0" id="closeContactPopup" style="background: rgba(255,255,255,0.15); width:28px; height:28px; border-radius:50%;">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <div class="contact-popup-body p-3 bg-white">
            <form id="quickContactForm">
                <div class="mb-3">
                    <input type="text" class="form-control" name="name" placeholder="Họ và tên của bạn *" required>
                </div>
                <div class="mb-3">
                    <input type="tel" class="form-control" name="phone" placeholder="Số điện thoại *" required pattern="[0-9]{9,11}">
                </div>
                
                <div class="mb-3">
                    <input type="text" class="form-control" name="need" placeholder="Bạn cần hỗ trợ gì? (VD: Mua sỉ táo)" required>
                    <div class="mt-2 d-flex gap-1 flex-wrap">
                        <span class="badge border cursor-pointer need-suggestion" style="background:#e8f5e9; color:#1b5e20; border-color:#a5d6a7 !important; font-size:0.78rem; padding: 5px 10px;">Mua giỏ quà</span>
                        <span class="badge border cursor-pointer need-suggestion" style="background:#e8f5e9; color:#1b5e20; border-color:#a5d6a7 !important; font-size:0.78rem; padding: 5px 10px;">Trái cây nhập</span>
                        <span class="badge border cursor-pointer need-suggestion" style="background:#e8f5e9; color:#1b5e20; border-color:#a5d6a7 !important; font-size:0.78rem; padding: 5px 10px;">Mua sỉ/Buôn</span>
                    </div>
                </div>

                <!-- Hidden block using Bootstrap Collapse -->
                <div class="mb-3 text-center">
                    <a class="text-muted text-decoration-none small toggle-extra-info" data-bs-toggle="collapse" href="#extraInfoCollapse" role="button" aria-expanded="false" aria-controls="extraInfoCollapse">
                        <i class="fas fa-plus-circle me-1"></i>Thêm Email/Ghi chú (Tuỳ chọn)
                    </a>
                </div>
                
                <div class="collapse" id="extraInfoCollapse">
                    <div class="mb-3">
                        <input type="email" class="form-control" name="email" placeholder="Địa chỉ Email">
                    </div>
                    <div class="mb-3">
                        <textarea class="form-control" name="note" rows="2" placeholder="Ghi chú thêm..."></textarea>
                    </div>
                </div>

                <input type="hidden" name="source_url" id="contactSourceUrl">

                <button type="submit" class="btn w-100 rounded-pill fw-bold text-white shadow-sm" id="btnSubmitContact"
                    style="background: linear-gradient(135deg, #1b5e20, #2e7d32); letter-spacing: 0.3px; padding: 0.65rem;">
                    Gửi yêu cầu ngay <i class="fas fa-paper-plane ms-1"></i>
                </button>
            </form>
            
            <div id="contactSuccessMsg" class="text-center py-4 d-none">
                <div class="mb-3 text-success">
                    <i class="fas fa-check-circle" style="font-size: 3rem;"></i>
                </div>
                <h6 class="fw-bold">Gửi thông tin thành công!</h6>
                <p class="small text-muted mb-0">Chuyên viên của chúng tôi sẽ liên hệ với bạn trong ít phút tới.</p>
            </div>
        </div>
    </div>

    <!-- Toggle Button -->
    <div class="floating-chat-toggle-wrapper" id="openContactPopup">
        <div class="contact-toggle-pill shadow-lg">
            <div class="icon-box pulse-animation">
                <i class="fas fa-comment-dots"></i>
            </div>
            <div class="text-label">Nhắn tin để được tư vấn</div>
        </div>
    </div>
</div>

<style>
    .floating-chat-container {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 1050;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        pointer-events: none; /* Allow clicks to pass through empty areas */
    }

    .floating-chat-toggle-wrapper {
        display: flex;
        align-items: center;
        margin-top: 15px;
        pointer-events: auto;
    }

    .contact-toggle-pill {
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, #2e7d32, #1b5e20);
        color: white;
        border-radius: 50px;
        padding: 5px;
        cursor: pointer;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        max-width: 52px; /* Showing only icon initially */
        height: 52px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .contact-toggle-pill:hover, 
    .contact-toggle-pill.force-expand {
        max-width: 300px;
        padding-right: 20px;
    }

    .icon-box {
        width: 42px;
        height: 42px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .contact-toggle-pill:hover .text-label,
    .contact-toggle-pill.force-expand .text-label {
        opacity: 1;
        width: auto;
        margin-left: 12px;
    }

    .text-label {
        white-space: nowrap;
        margin-left: 0;
        font-weight: 600;
        font-size: 0.95rem;
        opacity: 0;
        width: 0;
        transition: opacity 0.3s, margin-left 0.3s, width 0.3s;
    }
    
    .pulse-animation {
        animation: pulse-icon 2s infinite;
    }
    @keyframes pulse-icon {
        0% { transform: scale(1); }
        50% { transform: scale(1.1); }
        100% { transform: scale(1); }
    }

    .contact-popup-window {
        width: 320px;
        background: #fff;
        border-radius: 15px;
        overflow: hidden;
        transform-origin: bottom right;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        pointer-events: auto;
        position: absolute;
        bottom: 0px;
        right: 0;
    }

    @media (max-width: 576px) {
        .contact-popup-window {
            width: calc(100vw - 40px);
            right: 20px;
        }
        .floating-chat-container {
            bottom: 20px;
            right: 20px;
        }
    }

    .contact-popup-window.hidden-state {
        opacity: 0;
        transform: scale(0.5) translateY(40px); /* Smaller translate for better feel */
        pointer-events: none;
        visibility: hidden;
    }

    .contact-popup-header {
        border-bottom: 3px solid rgba(0,0,0,0.05);
    }

    .need-suggestion {
        transition: all 0.2s;
    }
    .need-suggestion:hover {
        background: #e9ecef !important;
        border-color: #adb5bd !important;
    }

    .contact-popup-body .form-control {
        border-radius: 8px;
        font-size: 0.92rem;
        padding: 0.65rem 1rem;
        background: #fff;
        border: 1.5px solid #ced4da;
        color: #212529;
    }
    .contact-popup-body .form-control:focus {
        background: #fff;
        border-color: #2e7d32;
        box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.2);
        color: #212529;
    }
    .contact-popup-body .form-control::placeholder {
        color: #6c757d;
        font-size: 0.88rem;
    }
    .contact-popup-body select.form-control {
        color: #212529;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const popup = document.getElementById('contactPopup');
    const openBtn = document.getElementById('openContactPopup');
    const closeBtn = document.getElementById('closeContactPopup');
    const tooltip = document.querySelector('.floating-chat-tooltip');
    const form = document.getElementById('quickContactForm');
    const successMsg = document.getElementById('contactSuccessMsg');
    const sourceUrlInput = document.getElementById('contactSourceUrl');
    
    // Set current URL
    sourceUrlInput.value = window.location.href;

    // Initial state
    popup.classList.add('hidden-state');
    popup.classList.remove('d-none'); // Using our custom hidden-state instead of d-none for animation

    // Periodic expand animation for the toggle label
    const togglePill = document.querySelector('.contact-toggle-pill');
    
    function triggerPeriodicExpand() {
        if (popup.classList.contains('hidden-state')) {
            togglePill.classList.add('force-expand');
            setTimeout(() => {
                togglePill.classList.remove('force-expand');
            }, 3000);
        }
    }

    // Trigger every 8 seconds (shows for 3s, hides for 5s)
    setInterval(triggerPeriodicExpand, 8000);
    // Also trigger once after 3s on load
    setTimeout(triggerPeriodicExpand, 3000);

    // Toggle Popup logic
    openBtn.addEventListener('click', () => {
        popup.classList.remove('hidden-state');
        openBtn.style.opacity = '0';
        openBtn.style.pointerEvents = 'none';
        togglePill.classList.remove('force-expand');
    });

    closeBtn.addEventListener('click', () => {
        popup.classList.add('hidden-state');
        openBtn.style.opacity = '1';
        openBtn.style.pointerEvents = 'auto';
    });

    // Need Suggestions Click
    document.querySelectorAll('.need-suggestion').forEach(badge => {
        badge.addEventListener('click', function() {
            document.querySelector('[name="need"]').value = this.innerText;
        });
    });

    // Form Submit
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = document.getElementById('btnSubmitContact');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang gửi...';

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
            const response = await fetch('/api/contacts', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();
            if (result.success) {
                form.style.display = 'none';
                successMsg.classList.remove('d-none');
                
                // Reset form sau 5 giây và đóng popup
                setTimeout(() => {
                    closeBtn.click();
                    setTimeout(() => {
                        form.reset();
                        form.style.display = 'block';
                        successMsg.classList.add('d-none');
                    }, 500);
                }, 4000);
            } else {
                Swal.fire('Lỗi', result.message || 'Không thể gửi yêu cầu', 'error');
            }
        } catch (error) {
            console.error('Lỗi khi gửi contact:', error);
            Swal.fire('Lỗi', 'Đã có lỗi xảy ra, vui lòng thử lại sau', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = 'Gửi yêu cầu ngay <i class="fas fa-paper-plane ms-1"></i>';
        }
    });
});
</script>
