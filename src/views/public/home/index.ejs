                { name: 'Nguyễn Thị Lan', role: 'Nội trợ, Cầu Giấy, Hà Nội', text: 'Mình đã mua táo Envy và nho Shine Muscat nhiều lần. Trái cây luôn tươi, giòn ngọt hơn hẳn siêu thị ngoài khu vực!', stars: 5 },
                { name: 'Nguyễn Văn Hùng', role: 'Doanh nhân, Hoàn Kiếm, Hà Nội', text: 'Tôi thường tặng hộp quà trái cây nhập khẩu cho đối tác. Cách đóng gói rất sang trọng, đối tác luôn ấn tượng.', stars: 5 },
                { name: 'Lê Thu Hà', role: 'Mẹ 2 con, Tây Hồ, Hà Nội', text: 'Con tôi rất thích dâu tây Seolhyang từ đây. Dâu to, ngọt, không chua như nơi khác. Giao hàng nhanh tận nhà ở Tây Hồ!', stars: 5 }
            ].forEach((r, i) => { %>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="<%= i * 150 %>">
                    <div class="testimonial-card">
                        <div class="d-flex gap-1 mb-3">
                            <% for(let s=0; s<r.stars; s++) { %><i class="fas fa-star text-warning"></i><% } %>
                        </div>
                        <p class="testimonial-text">"<%= r.text %>"</p>
                        <div class="testimonial-author mt-4">
                            <div class="author-avatar"><%= r.name.charAt(0) %></div>
                            <div>
                                <div class="fw-bold"><%= r.name %></div>
                                <small class="text-muted"><%= r.role %></small>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- ===== BLOG FEED ===== -->
<section class="section-padding bg-light-grey">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <p class="section-eyebrow" data-aos="fade-right">Góc kiến thức</p>
                <h2 class="section-title mb-0" data-aos="fade-right" data-aos-delay="100">Kiến Thức Trái Cây</h2>
            </div>
            <a href="/blog" class="btn btn-outline-primary rounded-pill px-4 d-none d-md-block">Xem tất cả</a>
        </div>
        <div class="row g-4">
            <% if (latestBlogs && latestBlogs.length > 0) { %>
                <% latestBlogs.forEach((b, i) => { %>
                    <div class="col-md-4" data-aos="fade-up" data-aos-delay="<%= i * 150 %>">
                        <a href="/blog/<%= b.slug %>" class="blog-card d-block h-100">
                            <div class="blog-img-wrap">
                                <img src="<%= b.thumbnail_url || 'https://images.unsplash.com/photo-1542838132-92c53300491e?w=600&q=80' %>" alt="<%= b.title %>" loading="lazy">
                                <span class="blog-tag">Tin mới</span>
                            </div>
                            <div class="blog-body">
                                <p class="blog-date"><i class="far fa-calendar me-1"></i><%= new Date(b.created_at).toLocaleDateString('vi-VN') %></p>
                                <h5 class="blog-title"><%= b.title %></h5>
                                <p class="small text-muted mb-3 line-clamp-2"><%= b.summary %></p>
                                <span class="blog-link">Đọc thêm <i class="fas fa-arrow-right ms-1"></i></span>
                            </div>
                        </a>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5 text-muted small italic">Chưa có bài viết mới.</div>
            <% } %>
        </div>
    </div>
</section>

<!-- ===== CSS for this page ===== -->
<style>
/* ---- Variables ---- */
:root {
    --hero-bg: #0f2d1f;
    --bg-light-grey: #f4f7f3;
}
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;  
    overflow: hidden;
}
.bg-light-grey { background: var(--bg-light-grey); }
.section-eyebrow {
    color: var(--brand-accent);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
}
.section-title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--brand-primary);
    line-height: 1.2;
}

/* ---- HERO ---- */
.hero-slider-section { position: relative; overflow: hidden; }
.hero-slide-item { min-height: 88vh; display: flex; align-items: center; position: relative; }
.hero-slide-item .container { position: relative; z-index: 2; }
.hero-eyebrow {
    color: #a3e9bc;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 1rem;
}
.hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #fff;
    line-height: 1.1;
}
.hero-title-accent { color: #6fcf97; }
.hero-subtitle { color: #cbd5e1; font-size: 1.05rem; max-width: 480px; margin-top: 1rem; line-height: 1.7; }
.heroSwiper .swiper-button-next, .heroSwiper .swiper-button-prev { color: #fff; transform: scale(0.7); }
.heroSwiper .swiper-pagination-bullet { background: #fff; opacity: 0.5; }
.heroSwiper .swiper-pagination-bullet-active { background: var(--brand-accent); opacity: 1; }

/* ---- TRUST BAR ---- */
.trust-bar-section {
    background: #fff;
    border-bottom: 1px solid #e8f5e9;
    padding: 16px 0;
}
.trust-bar-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
}
.trust-bar-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 24px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--brand-primary);
}
.trust-bar-divider {
    width: 1px; height: 32px;
    background: #e0e0e0;
}

/* ---- CATEGORIES ---- */
.cat-circle-item {
    display: flex; flex-direction: column; align-items: center;
    text-decoration: none; gap: 10px;
    transition: transform 0.3s ease;
}
.cat-circle-item:hover { transform: translateY(-6px); }
.cat-circle-img {
    width: 90px; height: 90px;
    border-radius: 50%;
    background: var(--bg-light-grey);
    border: 3px solid #e8f5e9;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
}
.cat-circle-item:hover .cat-circle-img {
    border-color: var(--brand-accent);
    box-shadow: 0 8px 20px rgba(46,125,50,0.2);
}
.cat-circle-img img { width: 100%; height: 100%; object-fit: cover; }
.cat-emoji { font-size: 2.2rem; }
.cat-circle-name {
    font-size: 0.82rem; font-weight: 600; text-align: center;
    color: var(--brand-primary);
}

/* ---- PRODUCT CARDS ---- */
.fruit-card {
    border: 1px solid #eee;
    border-radius: 18px;
    overflow: hidden;
    background: #fff;
    transition: all 0.3s ease;
    color: inherit;
}
.fruit-card:hover { transform: translateY(-6px); box-shadow: 0 16px 36px rgba(0,0,0,0.1); }
.fruit-card-img-wrap { position: relative; overflow: hidden; padding-top: 75%; background: var(--bg-light-grey); }
.fruit-card-img-wrap img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.fruit-card:hover .fruit-card-img-wrap img { transform: scale(1.06); }
.fruit-card-placeholder {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    font-size: 3rem; color: #ccc;
}
.fruit-tag {
    position: absolute; top: 12px; left: 12px;
    padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600;
}
.fruit-tag.hot { background: #fee2e2; color: #dc2626; }
.fruit-tag.new { background: #e0f2fe; color: #0369a1; }
.fruit-tag.discount { background: var(--brand-accent); color: #fff; top: 12px; right: 12px; left: auto; }
.fruit-card-body { padding: 16px; }
.fruit-card-name {
    font-family: var(--font-heading);
    font-size: 1rem; line-height: 1.3;
    color: var(--brand-primary); margin-bottom: 8px;
}
.price-main { font-size: 1.1rem; font-weight: 700; color: var(--brand-accent); }
.price-old { font-size: 0.85rem; color: #9ca3af; text-decoration: line-through; margin-left: 6px; }
.fruit-card-unit { font-size: 0.8rem; color: var(--text-muted); margin: 4px 0 0; }

/* ---- COMBO SECTION ---- */
.combo-section { background: #fff; }
.combo-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.06);
    transition: all 0.35s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
}
.combo-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.12);
}
.combo-card-img-wrap {
    position: relative;
    overflow: hidden;
    height: 200px;
}
.combo-card-img-wrap img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.5s ease;
}
.combo-card:hover .combo-card-img-wrap img { transform: scale(1.08); }
.combo-card-badge {
    position: absolute; top: 12px; right: 12px;
    background: var(--combo-accent, #2e7d32);
    color: #fff;
    font-size: 0.72rem; font-weight: 700;
    padding: 4px 12px; border-radius: 20px;
    letter-spacing: 0.03em;
}
.combo-card-body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
}
.combo-icon { font-size: 1.8rem; margin-bottom: 8px; }
.combo-label {
    font-size: 0.75rem; font-weight: 700;
    color: var(--combo-accent, var(--brand-accent));
    text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: 4px;
}
.combo-title {
    font-family: var(--font-heading);
    font-size: 1.15rem; color: var(--brand-primary);
    margin-bottom: 8px; line-height: 1.3;
}
.combo-desc {
    font-size: 0.83rem; color: var(--text-muted);
    line-height: 1.6; flex: 1;
    margin-bottom: 16px;
}
.combo-cta {
    display: inline-flex; align-items: center;
    font-size: 0.88rem; font-weight: 700;
    color: var(--combo-accent, var(--brand-accent));
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s ease;
    padding-bottom: 2px;
    width: fit-content;
}
.combo-cta:hover {
    border-color: var(--combo-accent, var(--brand-accent));
    color: var(--combo-accent, var(--brand-accent));
}

/* ---- WHY US ---- */
.why-card {
    border-radius: 18px; padding: 28px;
    height: 100%;
    transition: transform 0.3s ease;
}
.why-card:hover { transform: translateY(-4px); }
.why-icon { font-size: 1.8rem; color: var(--brand-primary); margin-bottom: 12px; }
.why-title { font-weight: 700; color: var(--brand-primary); margin-bottom: 8px; }
.why-desc { font-size: 0.875rem; color: var(--text-muted); margin: 0; }

/* ---- TESTIMONIALS ---- */
.testimonials-section { background: #fff; }
.testimonial-card {
    background: var(--bg-light-grey);
    border-radius: 20px; padding: 32px;
    height: 100%;
    transition: all 0.3s ease;
}
.testimonial-card:hover { background: var(--brand-light-green); }
.testimonial-text { font-family: var(--font-heading); font-size: 1.05rem; font-style: italic; color: var(--brand-primary); line-height: 1.6; }
.testimonial-author { display: flex; align-items: center; gap: 14px; }
.author-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--brand-accent);
    color: #fff; font-weight: 700; font-size: 1.1rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}

/* ---- BLOG ---- */
.blog-card {
    border-radius: 16px; overflow: hidden;
    background: #fff; border: 1px solid #eee;
    text-decoration: none; color: inherit;
    transition: all 0.3s ease;
}
.blog-card:hover { transform: translateY(-5px); box-shadow: 0 12px 32px rgba(0,0,0,0.09); }
.blog-img-wrap { position: relative; overflow: hidden; padding-top: 58%; }
.blog-img-wrap img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.blog-card:hover .blog-img-wrap img { transform: scale(1.04); }
.blog-tag { position: absolute; top: 12px; left: 12px; background: var(--brand-accent); color: #fff; font-size: 0.72rem; font-weight: 700; padding: 4px 10px; border-radius: 20px; }
.blog-body { padding: 20px; }
.blog-date { font-size: 0.78rem; color: var(--text-muted); margin-bottom: 8px; }
.blog-title { font-family: var(--font-heading); font-size: 1rem; color: var(--brand-primary); line-height: 1.4; margin-bottom: 8px; }
.blog-link { font-size: 0.85rem; font-weight: 600; color: var(--brand-accent); }

/* ---- FLASH SALE ---- */
.countdown-box {
    display: inline-block;
    background: #dc3545;
    color: white;
    padding: 3px 8px;
    border-radius: 4px;
    margin: 0 4px;
    font-size: 0.95rem;
    min-width: 35px;
    text-align: center;
}

@media (max-width: 768px) {
    .hero-slide-item { min-height: 60vh; }
    .hero-title { font-size: 2.2rem; }
    .cat-circle-img { width: 70px; height: 70px; }
    .trust-bar-item { font-size: 0.78rem; padding: 8px 12px; }
    .trust-bar-divider { display: none; }
    .combo-card-img-wrap { height: 160px; }
}
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const swiper = new Swiper('.heroSwiper', {
            loop: true,
            autoplay: { delay: 5500, disableOnInteraction: false },
            pagination: { el: '.swiper-pagination', clickable: true },
            navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
            effect: 'fade',
            fadeEffect: { crossFade: true }
        });

        // Flash Sale Countdown Logic
        const cdContainer = document.querySelector('.countdown-timer');
        if (cdContainer) {
            const endDateStr = cdContainer.getAttribute('data-countdown');
            if (endDateStr) {
                const countDownDate = new Date(endDateStr).getTime();
                let cdInterval = setInterval(function() {
                    const now = new Date().getTime();
                    const distance = countDownDate - now;

                    if (distance < 0) {
                        clearInterval(cdInterval);
                        cdContainer.innerHTML = "<span class='badge bg-danger'>ĐÃ KẾT THÚC</span>";
                        return;
                    }

                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)) + Math.floor(distance / (1000 * 60 * 60 * 24)) * 24;
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                    cdContainer.querySelector('.cd-hours').innerText = hours.toString().padStart(2, '0');
                    cdContainer.querySelector('.cd-minutes').innerText = minutes.toString().padStart(2, '0');
                    cdContainer.querySelector('.cd-seconds').innerText = seconds.toString().padStart(2, '0');
                }, 1000);
            }
        }
    });
</script>
