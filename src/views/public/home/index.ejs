<!-- ===== HERO SECTION (Dynamic Slider) ===== -->
<section class="hero-slider-section">
    <div class="swiper heroSwiper">
        <div class="swiper-wrapper">
            <% if (banners && banners.length > 0) { %>
                <% banners.forEach(banner => { %>
                    <div class="swiper-slide">
                        <div class="hero-slide-item" style="background: linear-gradient(rgba(15, 45, 31, 0.65), rgba(15, 45, 31, 0.45)), url('<%= banner.image_url %>') center/cover no-repeat;">
                            <div class="container h-100">
                                <div class="row h-100 align-items-center">
                                    <div class="col-lg-7 text-white">
                                        <% if (banner.title) { %>
                                            <h2 class="display-3 fw-bold mb-3 animate__animated animate__fadeInUp"><%= banner.title %></h2>
                                        <% } %>
                                        <% if (banner.subtitle) { %>
                                            <p class="lead mb-4 animate__animated animate__fadeInUp animate__delay-1s opacity-75"><%= banner.subtitle %></p>
                                        <% } %>
                                        <% if (banner.link_url) { %>
                                            <a href="<%= banner.link_url %>" class="btn btn-primary btn-lg rounded-pill px-5 animate__animated animate__fadeInUp animate__delay-2s">Khám phá ngay</a>
                                        <% } else { %>
                                            <a href="/products" class="btn btn-primary btn-lg rounded-pill px-5 animate__animated animate__fadeInUp animate__delay-2s">Mua sắm ngay</a>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <!-- Fallback slides — 3 slides trái cây đẹp -->
                <div class="swiper-slide">
                    <div class="hero-slide-item" style="background: linear-gradient(135deg, rgba(15,45,31,0.75) 0%, rgba(27,77,62,0.6) 100%), url('https://images.unsplash.com/photo-1610832958506-aa56368176cf?w=1400&q=80') center/cover no-repeat;">
                        <div class="container h-100">
                            <div class="row h-100 align-items-center">
                                <div class="col-lg-7 text-white">
                                    <p class="hero-eyebrow">🍃 Nhập khẩu chính hãng • Tươi ngon mỗi ngày</p>
                                    <h1 class="hero-title">Tinh Hoa <br>Trái Cây <span class="hero-title-accent">Nhập Khẩu</span><br>Toàn Cầu.</h1>
                                    <p class="hero-subtitle">Hàng trăm loại trái cây tươi ngon từ Hàn Quốc, Nhật Bản, Mỹ, Úc — cam kết chất lượng, giao tận cửa.</p>
                                    <div class="d-flex gap-3 flex-wrap mt-4">
                                        <a href="/products" class="btn btn-primary btn-lg rounded-pill px-5">Mua sắm ngay</a>
                                        <a href="/products?status=on_sale" class="btn btn-outline-light btn-lg rounded-pill px-4">Xem ưu đãi →</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="swiper-slide">
                    <div class="hero-slide-item" style="background: linear-gradient(135deg, rgba(10,40,26,0.80) 0%, rgba(46,90,40,0.55) 100%), url('https://images.unsplash.com/photo-1619566636858-adf3ef46400b?w=1400&q=80') center/cover no-repeat;">
                        <div class="container h-100">
                            <div class="row h-100 align-items-center">
                                <div class="col-lg-7 text-white">
                                    <p class="hero-eyebrow">🎁 Quà tặng sang trọng • Ấn tượng đầu tiên</p>
                                    <h1 class="hero-title">Giỏ Quà <span class="hero-title-accent">Trái Cây</span><br>Cao Cấp<br>Cho Mọi Dịp.</h1>
                                    <p class="hero-subtitle">Táo Envy, Nho Shine Muscat, Lê Hàn Quốc — đóng hộp sang trọng, phù hợp biếu tặng đối tác, gia đình.</p>
                                    <div class="d-flex gap-3 flex-wrap mt-4">
                                        <a href="/products" class="btn btn-primary btn-lg rounded-pill px-5">Chọn ngay</a>
                                        <a href="/contact" class="btn btn-outline-light btn-lg rounded-pill px-4">Tư vấn miễn phí</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="swiper-slide">
                    <div class="hero-slide-item" style="background: linear-gradient(135deg, rgba(20,55,35,0.72) 0%, rgba(60,110,55,0.50) 100%), url('https://images.unsplash.com/photo-1568702846914-96b305d2aaeb?w=1400&q=80') center/cover no-repeat;">
                        <div class="container h-100">
                            <div class="row h-100 align-items-center">
                                <div class="col-lg-7 text-white">
                                    <p class="hero-eyebrow">🌿 Organic • Kiểm định nhập khẩu • An toàn</p>
                                    <h1 class="hero-title">Sức Khỏe <span class="hero-title-accent">Từ Thiên Nhiên</span><br>Đến Bàn Ăn<br>Của Bạn.</h1>
                                    <p class="hero-subtitle">Mỗi sản phẩm đều có giấy kiểm định nhập khẩu, bảo quản lạnh chuẩn quốc tế, tươi ngon đến tay bạn.</p>
                                    <div class="d-flex gap-3 flex-wrap mt-4">
                                        <a href="/products" class="btn btn-primary btn-lg rounded-pill px-5">Khám phá ngay</a>
                                        <a href="/about" class="btn btn-outline-light btn-lg rounded-pill px-4">Về chúng tôi</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
        <div class="swiper-pagination"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
    </div>
</section>

<!-- ===== TRUST BADGES BAR ===== -->
<section class="trust-bar-section">
    <div class="container">
        <div class="trust-bar-inner">
            <div class="trust-bar-item">
                <i class="fas fa-certificate text-success"></i>
                <span>Nhập khẩu chính hãng</span>
            </div>
            <div class="trust-bar-divider"></div>
            <div class="trust-bar-item">
                <i class="fas fa-truck text-primary"></i>
                <span>Giao hàng nội thành Hà Nội trong ngày</span>
            </div>
            <div class="trust-bar-divider"></div>
            <div class="trust-bar-item">
                <i class="fas fa-undo text-warning"></i>
                <span>Đổi trả dễ dàng 24h</span>
            </div>
            <div class="trust-bar-divider"></div>
            <div class="trust-bar-item">
                <i class="fas fa-headset text-danger"></i>
                <span>CSKH 8:00 - 21:00 mỗi ngày</span>
            </div>
        </div>
    </div>
</section>

<!-- ===== CATEGORIES CIRCLES ===== -->
<section class="section-padding" id="categories">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <p class="section-eyebrow">Đa dạng lựa chọn</p>
            <h2 class="section-title">Khám Phá Thiên Đường<br>Trái Cây</h2>
        </div>
        <div class="row justify-content-center g-4">
            <% const catIcons = ['🍎','🍇','🍓','🍊','🍋','🍌','🥝','🍑']; %>
            <% if (categories && categories.length > 0) { %>
                <% categories.forEach((cat, i) => { %>
                    <div class="col-4 col-sm-3 col-md-2" data-aos="zoom-in" data-aos-delay="<%= i * 50 %>">
                        <a href="/products?category=<%= cat.slug %>" class="cat-circle-item">
                            <div class="cat-circle-img">
                                <% if (cat.image_url) { %>
                                    <img src="<%= cat.image_url %>" alt="<%= cat.name %>" loading="lazy">
                                <% } else { %>
                                    <span class="cat-emoji"><%= catIcons[i % catIcons.length] %></span>
                                <% } %>
                            </div>
                            <span class="cat-circle-name"><%= cat.name %></span>
                        </a>
                    </div>
                <% }) %>
            <% } else { %>
                <% ['Táo Nhập', 'Nho Tươi', 'Dâu Tây', 'Cam Vàng', 'Lê Nhập', 'Xoài'].forEach((name, i) => { %>
                    <div class="col-4 col-sm-3 col-md-2">
                        <a href="/products" class="cat-circle-item">
                            <div class="cat-circle-img">
                                <span class="cat-emoji"><%= catIcons[i] %></span>
                            </div>
                            <span class="cat-circle-name"><%= name %></span>
                        </a>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>
</section>

<!-- ===== FLASH SALE ===== -->
<% if (flashSaleProducts && flashSaleProducts.length > 0) { %>
<section class="section-padding bg-danger-subtle flash-sale-section">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4" data-aos="fade-right">
            <div>
                <h2 class="section-title text-danger mb-0"><i class="fas fa-bolt me-2"></i>Flash Sale Khung Giờ Vàng</h2>
                <div class="countdown-timer text-danger fw-bold mt-2 d-flex align-items-center" data-countdown="<%= flashSaleProducts[0].flash_sale_end %>">
                    Kết thúc trong: 
                    <span class="countdown-box ms-2 cd-hours">00</span>:
                    <span class="countdown-box cd-minutes">00</span>:
                    <span class="countdown-box cd-seconds">00</span>
                </div>
            </div>
            <a href="/products" class="btn btn-danger rounded-pill px-4 d-none d-md-block" data-aos="fade-left">MUA NGAY <i class="fas fa-angle-right ms-1"></i></a>
        </div>
        
        <div class="row g-4">
            <% flashSaleProducts.forEach((p, i) => { %>
                <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
                    <a href="/product/<%= p.slug %>" class="fruit-card d-block text-decoration-none" style="border: 2px solid #dc3545;">
                        <div class="fruit-card-img-wrap">
                            <% if (p.images && p.images.length > 0) { %>
                                <img src="<%= p.images[0].image_url %>" alt="<%= p.name %>" loading="lazy">
                            <% } else { %>
                                <div class="fruit-card-placeholder"><i class="fas fa-apple-whole"></i></div>
                            <% } %>
                            <% if (p.price && p.flash_sale_price) { %>
                                <span class="fruit-tag discount" style="background: red;">
                                    -<%= Math.round((p.price - p.flash_sale_price) / p.price * 100) %>% 
                                </span>
                            <% } %>
                        </div>
                        <div class="fruit-card-body">
                            <h5 class="fruit-card-name"><%= p.name %></h5>
                            <div class="fruit-card-price-wrap">
                                <span class="price-main text-danger fs-5">
                                    <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.flash_sale_price) %>
                                </span>
                                <span class="price-old">
                                    <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.price) %>
                                </span>
                            </div>
                            <div class="progress mt-2" style="height: 8px;">
                                <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" role="progressbar" style="width: 85%"></div>
                            </div>
                            <p class="small text-danger mt-1 mb-0 text-center fw-bold" style="font-size: 0.75rem;">Đang bán chạy</p>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- ===== FEATURED PRODUCTS ===== -->
<section class="section-padding bg-light-grey">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5" data-aos="fade-right">
            <div>
                <p class="section-eyebrow">Lựa chọn hôm nay</p>
                <h2 class="section-title mb-0">Sản Phẩm Yêu Thích<br>Trong Mùa</h2>
            </div>
            <a href="/products" class="btn btn-outline-primary rounded-pill px-4 d-none d-md-block" data-aos="fade-left">
                Xem tất cả <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="row g-4">
            <%
                // Dedup: ưu tiên bestSellers trước, rồi featured, không trùng ID
                const seenIds = new Map();
                (bestSellers || []).forEach(p => { if (!seenIds.has(p.id)) seenIds.set(p.id, { ...p, _priority: 'best_seller' }); });
                (featuredProducts || []).forEach(p => { if (!seenIds.has(p.id)) seenIds.set(p.id, { ...p, _priority: 'featured' }); });
                const allProducts = [...seenIds.values()].slice(0, 4);
            %>
            <% if (allProducts.length > 0) { %>
                <% allProducts.forEach((p, i) => { %>
                    <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="<%= i * 100 %>">
                        <a href="/product/<%= p.slug %>" class="fruit-card d-block text-decoration-none">
                            <div class="fruit-card-img-wrap">
                                <% if (p.images && p.images.length > 0) { %>
                                    <img src="<%= p.images[0].image_url %>" alt="<%= p.name %>" loading="lazy">
                                <% } else { %>
                                    <div class="fruit-card-placeholder">
                                        <i class="fas fa-apple-whole"></i>
                                    </div>
                                <% } %>
                                <% if (p.is_best_seller) { %>
                                    <span class="fruit-tag hot">Bán chạy 🔥</span>
                                <% } else if (p.is_featured) { %>
                                    <span class="fruit-tag new">Nổi bật ✨</span>
                                <% } %>
                                <% if (p.discountPercent > 0) { %>
                                    <span class="fruit-tag discount">-<%= p.discountPercent %>%</span>
                                <% } %>
                            </div>
                            <div class="fruit-card-body">
                                <h5 class="fruit-card-name"><%= p.name %></h5>
                                <div class="fruit-card-price-wrap">
                                    <span class="price-main">
                                        <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.bestPrice) %>
                                    </span>
                                    <% if (p.isDiscounted) { %>
                                        <span class="price-old">
                                            <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.originalPrice) %>
                                        </span>
                                    <% } %>
                                </div>
                                <p class="fruit-card-unit"><%= p.unit || 'kg' %> · <%= p.origin_country || '' %></p>
                            </div>
                        </a>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5 text-muted">
                    <i class="fas fa-box-open fa-3x mb-3 opacity-25"></i>
                    <p>Chưa có sản phẩm nào. Vui lòng quay lại sau!</p>
                </div>
            <% } %>
        </div>
        <div class="text-center mt-4 d-md-none">
            <a href="/products" class="btn btn-outline-primary rounded-pill px-4">Xem tất cả sản phẩm</a>
        </div>
    </div>
</section>

