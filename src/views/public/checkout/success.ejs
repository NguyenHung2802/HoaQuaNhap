<section class="py-5">
    <div class="container text-center">
        <div class="mb-4">
            <i class="fas fa-check-circle text-success fa-5x"></i>
        </div>
        <h1 class="font-heading text-primary mb-3">Đặt hàng thành công!</h1>
        <p class="lead mb-4">Cảm ơn bạn đã tin tưởng WebHoaQua. Mã đơn hàng của bạn là: <strong class="text-accent">#<%= order.order_code %></strong></p>
        
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <!-- Payment Information -->
                <% if (order.payment_method === 'BANK_TRANSFER') { %>
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                        <div class="card-header bg-primary text-white py-3">
                            <h5 class="mb-0 fw-bold">Thông tin chuyển khoản</h5>
                        </div>
                        <div class="card-body p-4">
                            <p class="text-muted small mb-4">Vui lòng quét mã QR bên dưới hoặc chuyển khoản chính xác nội dung để đơn hàng được xác nhận nhanh nhất.</p>
                            
                            <% if (qrUrl) { %>
                                <div class="qr-container mb-4">
                                    <img src="<%= qrUrl %>" alt="VietQR Payment" class="img-fluid border rounded-3 p-2 shadow-sm" style="max-width: 280px;">
                                </div>
                            <% } %>

                            <div class="bank-details text-start bg-light p-3 rounded-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Ngân hàng:</span>
                                    <span class="fw-bold"><%= bankDisplayName %></span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Số tài khoản:</span>
                                    <span class="fw-bold text-primary fs-5"><%= bankConfig.bank_account_no || 'N/A' %></span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Chủ tài khoản:</span>
                                    <span class="fw-bold"><%= bankConfig.bank_account_name || 'WEBHOAQUA' %></span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Phí vận chuyển:</span>
                                    <span class="fw-bold text-dark">Tùy địa điểm</span>
                                </div>
                                <% if (order.shipping_campaign_id) { %>
                                    <div class="alert alert-success py-2 px-3 small border-0 mb-2">
                                        <i class="fas fa-gift me-1"></i> 
                                        <strong>Ưu đãi:</strong> Giảm <%= order.shipping_discount_amount %><%= order.shipping_campaign_id ? (order.shipping_discount_amount < 100 ? '%' : 'đ') : '' %> phí ship (Admin sẽ trừ khi liên hệ).
                                    </div>
                                <% } %>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Giảm giá sản phẩm:</span>
                                    <span class="fw-bold text-danger">- <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(order.discount_amount) %></span>
                                </div>
                                <div class="d-flex justify-content-between mb-2 pt-2 border-top">
                                    <span class="text-muted small">Tổng thanh toán:</span>
                                    <span class="fw-bold text-primary fs-4"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(order.total_amount) %></span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted small">Nội dung:</span>
                                    <span class="fw-bold text-accent"><%= order.order_code %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="card border-0 shadow-sm rounded-4 p-5 mb-4">
                        <i class="fas fa-truck text-muted fa-3x mb-3"></i>
                        <h5>Thanh toán khi nhận hàng (COD)</h5>
                        <p class="text-muted small">Đội ngũ CSKH sẽ sớm liên hệ với bạn để xác nhận đơn hàng.</p>
                    </div>
                <% } %>

                <div class="d-flex flex-column flex-md-row gap-3 justify-content-center">
                    <a href="/products" class="btn btn-primary rounded-pill px-5 fw-bold">Tiếp tục mua sắm</a>
                    <a href="/orders" class="btn btn-outline-secondary rounded-pill px-5">Xem đơn hàng</a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .text-accent { color: #2e7d32; }
    .bg-primary { background-color: #2e7d32 !important; }
    .text-primary { color: #2e7d32 !important; }
</style>
