<!-- Breadcrumb -->
<div class="bg-light-grey py-3 border-bottom">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active">Sản phẩm</li>
            </ol>
        </nav>
    </div>
</div>

<section class="section-padding">
    <div class="container">
        <div class="row g-5">
            <!-- ===== SIDEBAR ===== -->
            <div class="col-lg-3" data-aos="fade-right">
                <div class="shop-sidebar">
                    <form action="/products" method="GET" id="filterForm">
                        <!-- Search -->
                        <div class="sidebar-block">
                            <h6 class="sidebar-title">Tìm kiếm</h6>
                            <div class="input-group">
                                <input type="text" name="q" class="form-control rounded-start-pill border-end-0 bg-light"
                                       placeholder="Tên sản phẩm..." value="<%= filters.q %>">
                                <input type="hidden" name="sort" id="hiddenSort" value="<%= filters.sort %>">
                                <button class="btn btn-outline-secondary rounded-end-pill border-start-0 bg-light" type="submit">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Categories -->
                        <div class="sidebar-block">
                            <h6 class="sidebar-title">Danh mục</h6>
                            <div class="d-flex flex-column gap-2">
                                <label class="cat-filter-item d-flex justify-content-between align-items-center <%= !filters.category ? 'active' : '' %>" style="cursor: pointer;">
                                    <input type="radio" name="category" value="" class="d-none" onchange="this.form.submit()" <%= !filters.category ? 'checked' : '' %>>
                                    <span>Tất cả sản phẩm</span>
                                    <span class="badge bg-light text-dark rounded-pill border"><%= total %></span>
                                </label>
                                <% categories.forEach(cat => { %>
                                    <label class="cat-filter-item d-flex justify-content-between align-items-center <%= filters.category === cat.slug ? 'active' : '' %>" style="cursor: pointer;">
                                        <input type="radio" name="category" value="<%= cat.slug %>" class="d-none" onchange="this.form.submit()" <%= filters.category === cat.slug ? 'checked' : '' %>>
                                        <span><%= cat.name %></span>
                                        <span class="badge bg-light text-dark rounded-pill border"><%= cat._count.products %></span>
                                    </label>
                                <% }) %>
                            </div>
                        </div>

                        <!-- Origin -->
                        <div class="sidebar-block">
                            <h6 class="sidebar-title">Nguồn gốc</h6>
                            <div class="d-flex flex-column gap-2">
                                <% distinctOrigins.forEach(org => { %>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="origin" value="<%= org.origin_country %>" id="origin_<%= org.origin_country %>" onchange="this.form.submit()" <%= filters.origin.includes(org.origin_country) ? 'checked' : '' %>>
                                        <label class="form-check-label text-muted small" style="cursor: pointer;" for="origin_<%= org.origin_country %>">
                                            <%= org.origin_country %> (<%= org._count.origin_country %>)
                                        </label>
                                    </div>
                                <% }) %>
                            </div>
                        </div>

                        <!-- Khoảng giá -->
                        <div class="sidebar-block">
                            <h6 class="sidebar-title">Khoảng giá</h6>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <input type="number" class="form-control form-control-sm bg-light border-0" name="minPrice" placeholder="Tối thiểu" value="<%= filters.minPrice %>" onchange="if(this.value && this.form.maxPrice.value && parseInt(this.value) > parseInt(this.form.maxPrice.value)) this.value='';">
                                </div>
                                <div class="col-6">
                                    <input type="number" class="form-control form-control-sm bg-light border-0" name="maxPrice" placeholder="Tối đa" value="<%= filters.maxPrice %>" onchange="if(this.value && this.form.minPrice.value && parseInt(this.value) < parseInt(this.form.minPrice.value)) this.value='';">
                                </div>
                            </div>
                            <button type="submit" class="btn btn-outline-success btn-sm w-100 rounded-pill mt-1">Áp dụng giá</button>
                        </div>

                        <!-- Trạng thái -->
                        <div class="sidebar-block align-items-center">
                            <h6 class="sidebar-title">Trạng thái</h6>
                            <div class="d-flex flex-wrap gap-2">
                                <label class="status-chip" style="cursor: pointer;">
                                    <input type="checkbox" name="status" value="new_arrival" class="d-none" onchange="this.form.submit()" <%= filters.status.includes('new_arrival') ? 'checked' : '' %>>
                                    <span class="badge rounded-pill border px-3 py-2 <%= filters.status.includes('new_arrival') ? 'bg-success text-white border-success' : 'bg-light text-dark' %>" style="transition: all 0.2s;">Mới về</span>
                                </label>
                                <label class="status-chip" style="cursor: pointer;">
                                    <input type="checkbox" name="status" value="in_stock" class="d-none" onchange="this.form.submit()" <%= filters.status.includes('in_stock') ? 'checked' : '' %>>
                                    <span class="badge rounded-pill border px-3 py-2 <%= filters.status.includes('in_stock') ? 'bg-success text-white border-success' : 'bg-light text-dark' %>" style="transition: all 0.2s;">Sẵn có</span>
                                </label>
                                <label class="status-chip" style="cursor: pointer;">
                                    <input type="checkbox" name="status" value="on_sale" class="d-none" onchange="this.form.submit()" <%= filters.status.includes('on_sale') ? 'checked' : '' %>>
                                    <span class="badge rounded-pill border px-3 py-2 <%= filters.status.includes('on_sale') ? 'bg-success text-white border-success' : 'bg-light text-dark' %>" style="transition: all 0.2s;">Giảm giá</span>
                                </label>
                            </div>
                        </div>

                        <!-- Clear -->
                        <a href="/products" class="btn btn-light w-100 rounded-pill border small mt-2">
                            <i class="fas fa-times-circle me-1"></i> Xóa bộ lọc
                        </a>
                    </form>
                </div>
            </div>

            <!-- ===== PRODUCT GRID ===== -->
            <div class="col-lg-9">
                <!-- Toolbar -->
                <div class="shop-toolbar d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3" data-aos="fade-down">
                    <div class="text-muted small">
                        Hiển thị <strong><%= products.length %></strong> / <strong><%= total %></strong> sản phẩm
                        <% if (filters.q) { %> cho "<strong><%= filters.q %></strong>"<% } %>
                    </div>
                    <form id="sortForm" class="d-flex align-items-center gap-2">
                        <label class="text-muted small mb-0">Sắp xếp:</label>
                        <select name="sort" class="form-select form-select-sm rounded-pill border-0 bg-light" style="width:auto" onchange="document.getElementById('hiddenSort').value = this.value; document.getElementById('filterForm').submit();">
                            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
                            <option value="price_asc" <%= filters.sort === 'price_asc' ? 'selected' : '' %>>Giá: Thấp → Cao</option>
                            <option value="price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>Giá: Cao → Thấp</option>
                            <option value="name" <%= filters.sort === 'name' ? 'selected' : '' %>>Tên A → Z</option>
                        </select>
                    </form>
                </div>

                <!-- Grid -->
                <% if (products.length > 0) { %>
                    <div class="row row-cols-2 row-cols-md-3 g-4">
                        <% products.forEach((p, i) => { %>
                            <div class="col" data-aos="fade-up" data-aos-delay="<%= i * 50 %>">
                                <a href="/product/<%= p.slug %>" class="fruit-card d-block text-decoration-none h-100">
                                    <div class="fruit-card-img-wrap">
                                        <% if (p.images && p.images.length > 0) { %>
                                            <img src="<%= p.images[0].image_url %>" alt="<%= p.name %>" loading="lazy">
                                        <% } else { %>
                                            <div class="fruit-card-placeholder">🍎</div>
                                        <% } %>
                                        <% if (p.is_best_seller) { %><span class="fruit-tag hot">Bán chạy 🔥</span><% } %>
                                        <% if (p.is_featured && !p.is_best_seller) { %><span class="fruit-tag new">Nổi bật ✨</span><% } %>
                                        <% if (p.discountPercent > 0) { %>
                                            <span class="fruit-tag discount">-<%= p.discountPercent %>%</span>
                                        <% } %>
                                    </div>
                                    <div class="fruit-card-body">
                                        <% if (p.category) { %>
                                            <p class="fruit-card-cat"><%= p.category.name %></p>
                                        <% } %>
                                        <h5 class="fruit-card-name"><%= p.name %></h5>
                                        <div class="fruit-card-price-wrap">
                                            <span class="price-main text-accent fw-bold">
                                                <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.bestPrice) %>
                                            </span>
                                            <% if (p.isDiscounted) { %>
                                                <span class="price-old text-muted text-decoration-line-through small ms-2">
                                                    <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.originalPrice) %>
                                                </span>
                                            <% } %>
                                        </div>
                                        <p class="fruit-card-unit"><%= p.unit %> · <%= p.origin_country || '' %></p>
                                    </div>
                                </a>
                            </div>
                        <% }) %>
                    </div>

                    <!-- Pagination -->
                    <% if (totalPages > 1) { 
                        let pageUrl = '?';
                        if(filters.sort) pageUrl += `sort=${filters.sort}&`;
                        if(filters.q) pageUrl += `q=${filters.q}&`;
                        if(filters.category) pageUrl += `category=${filters.category}&`;
                        if(filters.minPrice) pageUrl += `minPrice=${filters.minPrice}&`;
                        if(filters.maxPrice) pageUrl += `maxPrice=${filters.maxPrice}&`;
                        filters.origin.forEach(o => pageUrl += `origin=${encodeURIComponent(o)}&`);
                        filters.status.forEach(s => pageUrl += `status=${encodeURIComponent(s)}&`);
                    %>
                        <nav class="mt-5 d-flex justify-content-center">
                            <ul class="pagination pagination-sm gap-1">
                                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                    <a class="page-link rounded-circle" href="<%= pageUrl %>page=<%= currentPage-1 %>">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                                <% for (let i = 1; i <= totalPages; i++) { %>
                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link rounded-circle" href="<%= pageUrl %>page=<%= i %>"><%= i %></a>
                                    </li>
                                <% } %>
                                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                    <a class="page-link rounded-circle" href="<%= pageUrl %>page=<%= currentPage+1 %>">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>

                <% } else { %>
                    <div class="text-center py-5">
                        <div style="font-size:4rem">🔍</div>
                        <h5 class="mt-3 text-muted">Không tìm thấy sản phẩm nào</h5>
                        <p class="text-muted small">Hãy thử tìm kiếm với từ khóa khác hoặc xóa bộ lọc.</p>
                        <a href="/products" class="btn btn-primary rounded-pill px-4 mt-2">Xem tất cả</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</section>

<style>
.bg-light-grey { background: #f4f7f3; }
.section-padding { padding: 60px 0; }
.section-eyebrow { color: var(--brand-accent); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.08em; }
.section-title { font-family: var(--font-heading); font-size: clamp(1.6rem, 2.5vw, 2.2rem); color: var(--brand-primary); }

/* Sidebar */
.shop-sidebar { position: sticky; top: 80px; }
.sidebar-block { margin-bottom: 28px; }
.sidebar-title { font-weight: 700; color: var(--brand-primary); margin-bottom: 14px; padding-bottom: 8px; border-bottom: 2px solid var(--brand-light-green); font-size: 0.95rem; }
.cat-filter-item { display: block; padding: 8px 14px; border-radius: 100px; font-size: 0.875rem; color: var(--text-muted); text-decoration: none; transition: all 0.2s ease; }
.cat-filter-item:hover, .cat-filter-item.active { background: var(--brand-light-green); color: var(--brand-primary); font-weight: 600; }

/* Product Cards (Same as home) */
.fruit-card { border: 1px solid #eee; border-radius: 18px; overflow: hidden; background: #fff; transition: all 0.3s ease; color: inherit; }
.fruit-card:hover { transform: translateY(-6px); box-shadow: 0 16px 36px rgba(0,0,0,0.1); }
.fruit-card-img-wrap { position: relative; overflow: hidden; padding-top: 75%; background: #f4f7f3; }
.fruit-card-img-wrap img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.fruit-card:hover .fruit-card-img-wrap img { transform: scale(1.06); }
.fruit-card-placeholder { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 3rem; }
.fruit-tag { position: absolute; top: 10px; left: 10px; padding: 3px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
.fruit-tag.hot { background: #fee2e2; color: #dc2626; }
.fruit-tag.new { background: #e0f2fe; color: #0369a1; }
.fruit-tag.discount { background: var(--brand-accent); color: #fff; top: 10px; right: 10px; left: auto; }
.fruit-card-body { padding: 16px; }
.fruit-card-cat { font-size: 0.75rem; color: var(--brand-accent); font-weight: 600; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
.fruit-card-name { font-family: var(--font-heading); font-size: 0.95rem; color: var(--brand-primary); margin-bottom: 8px; line-height: 1.3; }
.price-main { font-weight: 700; font-size: 1.05rem; color: var(--brand-accent); }
.price-old { font-size: 0.82rem; color: #9ca3af; text-decoration: line-through; margin-left: 6px; }
.fruit-card-unit { font-size: 0.78rem; color: var(--text-muted); margin: 4px 0 0; }

/* Pagination */
.pagination .page-link { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border: 1px solid #dee2e6; color: var(--brand-primary); font-size: 0.85rem; }
.pagination .page-item.active .page-link { background: var(--brand-primary); border-color: var(--brand-primary); }
</style>
