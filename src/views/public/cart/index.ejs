<!-- Breadcrumb -->
<div class="bg-light-grey py-3 border-bottom">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active">Giỏ hàng</li>
            </ol>
        </nav>
    </div>
</div>

<section class="cart-section py-5">
    <div class="container">
        <h1 class="font-heading text-primary mb-4">Giỏ hàng của bạn</h1>
        <% const money = (value) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(value); %>

        <% if (items && items.length > 0) { %>
            <% if (shippingPromotion) { %>
                <div class="freeship-bar mb-4 p-3 rounded-4 d-flex align-items-center gap-3"
                     style="background: linear-gradient(135deg, #f0fdf4, #dcfce7); border: 1px solid #86efac;">
                    <div class="freeship-icon flex-shrink-0">
                        <% if (shippingPromotion.reached) { %>
                            <span style="font-size: 2rem;">🎉</span>
                        <% } else { %>
                            <span style="font-size: 2rem;">🚚</span>
                        <% } %>
                    </div>
                    <div class="flex-grow-1">
                        <% if (shippingPromotion.reached) { %>
                            <div class="fw-bold text-success small mb-1">
                                <%= shippingPromotion.unlockedMessage %> — <em><%= shippingPromotion.campaignName %></em>
                            </div>
                        <% } else { %>
                            <div class="fw-bold text-success small mb-1">
                                <%= shippingPromotion.pendingMessage %> 🎁 — <em><%= shippingPromotion.campaignName %></em>
                            </div>
                        <% } %>
                        <div class="progress rounded-pill" style="height: 8px;">
                            <div class="progress-bar bg-success" role="progressbar"
                                 style="width: <%= shippingPromotion.progress %>%; transition: width 0.6s ease;"
                                 aria-valuenow="<%= shippingPromotion.progress %>" aria-valuemin="0" aria-valuemax="100">
                            </div>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted">0đ</small>
                            <small class="text-muted"><%= money(shippingPromotion.threshold) %></small>
                        </div>
                    </div>
                </div>
            <% } %>

            <div class="row g-5">
                <div class="col-lg-8">
                    <div class="cart-items-wrapper">
                        <% items.forEach(item => { %>
                            <div class="cart-item d-flex align-items-center gap-4 p-3 border-bottom <%= item.is_out_of_stock ? 'opacity-50' : '' %>" data-product-id="<%= item.product_id %>">
                                <div class="cart-item-img rounded-3 overflow-hidden" style="width: 100px; height: 100px; flex-shrink: 0; background: #f9f9f9;">
                                    <% if (item.image_url) { %>
                                        <img src="<%= item.image_url %>" alt="<%= item.name %>" class="w-100 h-100 object-fit-cover">
                                    <% } else { %>
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center display-4">🍎</div>
                                    <% } %>
                                </div>

                                <div class="cart-item-info flex-grow-1">
                                    <h5 class="mb-1 font-heading">
                                        <a href="/product/<%= item.slug %>" class="text-decoration-none text-dark"><%= item.name %></a>
                                    </h5>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="text-accent fw-bold"><%= money(item.price) %></span>
                                        <% if (item.is_discounted && item.original_price > item.price) { %>
                                            <span class="text-muted text-decoration-line-through small"><%= money(item.original_price) %></span>
                                        <% } %>
                                    </div>
                                    <% if (item.is_out_of_stock) { %>
                                        <span class="badge bg-danger">Hết hàng hoặc số lượng không đủ</span>
                                    <% } %>
                                </div>

                                <div class="cart-item-qty flex-shrink-0">
                                    <div class="qty-control border rounded-pill d-flex align-items-center bg-white px-2 py-1">
                                        <button type="button" class="btn btn-sm btn-link text-decoration-none text-dark" onclick="updateCartItem(<%= item.product_id %>, <%= item.quantity - 1 %>)">−</button>
                                        <input type="number" class="form-control form-control-sm border-0 text-center fw-bold bg-transparent" style="width: 45px;" value="<%= item.quantity %>" readonly>
                                        <button type="button" class="btn btn-sm btn-link text-decoration-none text-dark" onclick="updateCartItem(<%= item.product_id %>, <%= item.quantity + 1 %>)" <%= item.quantity >= item.stock_quantity ? 'disabled' : '' %>>+</button>
                                    </div>
                                    <div class="text-center mt-1">
                                        <small class="text-muted" style="font-size: 0.75rem;">(Kho: <%= item.stock_quantity %>)</small>
                                    </div>
                                </div>

                                <div class="cart-item-action text-end ms-3 flex-shrink-0" style="min-width: 120px;">
                                    <div class="fw-bold text-main mb-2"><%= money(item.line_total) %></div>
                                    <button type="button" class="btn btn-sm text-danger border-0 p-0" onclick="removeCartItem(<%= item.product_id %>)" title="Xóa">
                                        <i class="fas fa-trash-alt me-1"></i> Xóa
                                    </button>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                    <div class="mt-4">
                        <a href="/products" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-arrow-left me-2"></i> Tiếp tục mua sắm
                        </a>
                    </div>

                    <% if (suggestedProducts && suggestedProducts.length > 0) { %>
                        <div class="mt-5">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span style="font-size: 1.2rem;">🛒</span>
                                <h5 class="fw-bold font-heading mb-0 text-primary">Có thể bạn cũng thích</h5>
                            </div>
                            <div class="row g-3">
                                <% suggestedProducts.forEach(p => { %>
                                    <div class="col-md-6">
                                        <div class="suggested-card d-flex align-items-center gap-3 p-3 rounded-4 border bg-white h-100">
                                            <div class="suggested-img rounded-3 overflow-hidden flex-shrink-0" style="width: 80px; height: 80px; background: #f4f7f3;">
                                                <% if (p.images && p.images.length > 0) { %>
                                                    <img src="<%= p.images[0].image_url %>" alt="<%= p.name %>" class="w-100 h-100 object-fit-cover">
                                                <% } else { %>
                                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="font-size: 1.8rem;">🍎</div>
                                                <% } %>
                                            </div>
                                            <div class="flex-grow-1 min-w-0">
                                                <a href="/product/<%= p.slug %>" class="text-decoration-none">
                                                    <div class="fw-semibold text-dark small mb-1 text-truncate"><%= p.name %></div>
                                                </a>
                                                <div class="d-flex align-items-center gap-2 mb-2">
                                                    <span class="text-accent fw-bold small"><%= money(p.bestPrice) %></span>
                                                    <% if (p.isDiscounted) { %>
                                                        <span class="text-muted text-decoration-line-through" style="font-size: 0.75rem;"><%= money(p.originalPrice) %></span>
                                                    <% } %>
                                                </div>
                                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                                        onclick="addToCart(<%= p.id %>, 1)" style="font-size: 0.78rem;">
                                                    <i class="fas fa-plus me-1"></i>Thêm vào giỏ
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>
                </div>

                <div class="col-lg-4">
                    <div class="cart-summary bg-light-grey rounded-4 p-4 sticky-top" style="top: 100px;">
                        <h4 class="font-heading mb-4 border-bottom pb-3">Tóm tắt đơn hàng</h4>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tạm tính (<%= cartItemsCount %> sản phẩm)</span>
                            <span class="fw-bold"><%= money(totalAmount) %></span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Phí vận chuyển</span>
                            <span class="fw-bold <%= shippingPromotion && shippingPromotion.reached ? 'text-success' : 'text-dark' %>">
                                <%= shippingPromotion && shippingPromotion.reached ? shippingPromotion.benefitLabel : 'Tùy địa điểm' %>
                            </span>
                        </div>
                        <hr class="my-3">
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold fs-5">Tổng cộng</span>
                            <span class="fw-bold fs-5 text-accent"><%= money(totalAmount) %></span>
                        </div>

                        <% const hasErrors = items.some(i => i.is_out_of_stock); %>
                        <a href="/checkout" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold <%= hasErrors ? 'disabled' : '' %>">
                            Tiến hành thanh toán
                        </a>
                        <% if (hasErrors) { %>
                            <div class="text-danger small mt-2 text-center">Vui lòng điều chỉnh hoặc xóa các sản phẩm lỗi trước khi thanh toán.</div>
                        <% } %>

                        <% if (shippingPromotion && !shippingPromotion.reached) { %>
                            <div class="mt-3 p-3 rounded-3 text-center" style="background: #fefce8; border: 1px solid #fde68a;">
                                <small class="text-warning fw-bold">🚚 <%= shippingPromotion.pendingMessage %>!</small>
                            </div>
                        <% } else if (shippingPromotion && shippingPromotion.reached) { %>
                            <div class="mt-3 p-3 rounded-3 text-center" style="background: #f0fdf4; border: 1px solid #86efac;">
                                <small class="text-success fw-bold">✅ <%= shippingPromotion.unlockedMessage %></small>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <div class="display-1 text-muted mb-4"><i class="fas fa-shopping-basket"></i></div>
                <h3 class="font-heading text-muted">Giỏ hàng của bạn đang trống</h3>
                <p class="mb-4">Hãy lấp đầy giỏ hàng bằng những mặt hàng tươi ngon của chúng tôi nhé!</p>
                <a href="/products" class="btn btn-primary rounded-pill px-5">Tới cửa hàng</a>
            </div>
        <% } %>
    </div>
</section>

<style>
.bg-light-grey { background-color: #f4f7f3; }
.text-main { color: var(--brand-primary); }
.freeship-bar { transition: all 0.3s ease; }
.suggested-card { transition: all 0.25s ease; }
.suggested-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.09); border-color: var(--brand-accent) !important; }
</style>
