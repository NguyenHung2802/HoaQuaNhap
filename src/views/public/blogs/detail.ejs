<!-- ===== BREADCRUMB ===== -->
<nav class="bg-light py-3 border-bottom">
    <div class="container">
        <ol class="breadcrumb mb-0 small uppercase fw-bold" style="letter-spacing: 0.05em;">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/blogs" class="text-decoration-none text-muted">Tin tức</a></li>
            <li class="breadcrumb-item active text-truncate" aria-current="page"><%= blog.title %></li>
        </ol>
    </div>
</nav>

<section class="section-padding">
    <div class="container">
        <div class="row g-5">
            <!-- Article Body -->
            <div class="col-lg-8 blog-content-wrapper">
                <article class="blog-detail bg-white p-4 p-md-5 rounded-4 shadow-sm">
                    <header class="mb-4">
                        <div class="blog-date text-muted mb-2">
                            <i class="far fa-calendar-alt me-1"></i><%= new Date(blog.created_at).toLocaleDateString('vi-VN') %>
                            <span class="mx-2 opacity-50">|</span>
                            <i class="fas fa-user-edit me-1"></i><%= blog.author ? blog.author.full_name : 'Admin' %>
                        </div>
                        <h1 class="display-5 fw-bold text-dark lh-sm"><%= blog.title %></h1>
                        <% if (blog.summary) { %>
                            <p class="lead text-muted italic mt-3 ps-3 border-start border-3 border-primary-emphasis"><%= blog.summary %></p>
                        <% } %>
                    </header>

                    <% if (blog.thumbnail_url) { %>
                        <div class="mb-5 rounded-4 overflow-hidden border">
                            <img src="<%= blog.thumbnail_url %>" alt="<%= blog.title %>" class="w-100 object-fit-cover shadow-sm" style="max-height: 480px;">
                        </div>
                    <% } %>

                    <div class="blog-body ql-editor px-0 text-dark" style="font-size: 1.15rem; line-height: 1.8; color: #1a202c !important;">
                        <%- blog.content %>
                    </div>

                    <footer class="mt-5 pt-4 border-top">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="blog-tags">
                                <span class="badge bg-light text-muted border px-3 rounded-pill me-1">#tráicây</span>
                                <span class="badge bg-light text-muted border px-3 rounded-pill">#sứckhỏe</span>
                            </div>
                            <div class="blog-share d-flex align-items-center gap-3">
                                <span class="small text-muted fw-bold share-label">Chia sẻ:</span>
                                <a href="#" class="btn btn-sm btn-outline-primary rounded-circle" style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;"><i class="fab fa-facebook-f"></i></a>
                                <a href="#" class="btn btn-sm btn-outline-info rounded-circle text-info border-info" style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;"><i class="fab fa-twitter"></i></a>
                            </div>
                        </div>
                    </footer>
                </article>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4 blog-sidebar">
                <!-- Recent Posts -->
                <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
                    <h5 class="fw-bold mb-4 position-relative pb-2 section-underline">Bài viết mới nhất</h5>
                    <div class="list-group list-group-flush">
                        <% if (recentBlogs && recentBlogs.length > 0) { %>
                            <% recentBlogs.forEach(rb => { %>
                                <a href="/blog/<%= rb.slug %>" class="list-group-item list-group-item-action px-0 border-0 mb-3 bg-transparent">
                                    <div class="row align-items-center g-2">
                                        <div class="col-4">
                                            <div class="rounded-3 overflow-hidden" style="height: 65px;">
                                                <img src="<%= rb.thumbnail_url || 'https://via.placeholder.com/300x180' %>" alt="<%= rb.title %>" class="w-100 h-100 object-fit-cover shadow-sm">
                                            </div>
                                        </div>
                                        <div class="col-8">
                                            <h6 class="small fw-bold text-dark line-clamp-2 mb-1"><%= rb.title %></h6>
                                            <div class="small text-muted"><%= new Date(rb.created_at).toLocaleDateString('vi-VN') %></div>
                                        </div>
                                    </div>
                                </a>
                            <% }) %>
                        <% } else { %>
                            <p class="small text-muted italic">Hiện chưa có bài viết liên quan.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Promo Banner in Sidebar -->
                <div class="blog-sidebar-promo card shadow-sm border-0 rounded-4 overflow-hidden mb-4 bg-primary text-white p-4 text-center">
                    <div class="bg-white rounded-circle p-3 d-inline-flex mx-auto mb-3 shadow-sm" style="width: 70px; height: 70px; align-items: center; justify-content: center;">
                        <i class="fas fa-tags text-primary fs-3"></i>
                    </div>
                    <h5 class="fw-bold fs-4">Giao hàng miễn phí!</h5>
                    <p class="small opacity-75 mb-4 px-3">Tặng mã FREE SHIP cho đơn hàng đầu tiên từ 500.000₫. Đăng ký thành viên ngay hôm nay.</p>
                    <a href="/auth/register" class="btn btn-light rounded-pill btn-lg w-100 fw-bold fs-6">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quill Styles to ensure consistency -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<style>
    .section-underline::after {
        content: ''; position: absolute; bottom: 0; left: 0;
        width: 40px; height: 3px; background: var(--brand-accent);
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .blog-detail h1 { color: #2d3748 !important; }
    .blog-body h2 { font-weight: 800; font-family: var(--font-heading); color: var(--brand-primary); margin-top: 2.5rem; margin-bottom: 1.2rem; }
    .blog-body p { margin-bottom: 1.5rem; }
</style>
