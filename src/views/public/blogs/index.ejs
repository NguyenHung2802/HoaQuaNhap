<!-- ===== BREADCRUMB ===== -->
<nav class="bg-light py-3 border-bottom">
    <div class="container">
        <ol class="breadcrumb mb-0 small uppercase fw-bold" style="letter-spacing: 0.05em;">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Tin tức & Kiến thức</li>
        </ol>
    </div>
</nav>

<section class="section-padding">
    <div class="container">
        <div class="text-center mb-5">
            <p class="section-eyebrow">Góc kiến thức</p>
            <h2 class="section-title">Tin Tức Trái Cây<br>& Sức Khỏe</h2>
            <p class="text-muted mt-3 max-w-600 mx-auto">Cập nhật những kiến thức bổ ích về cách chọn, bảo quản trái cây nhập khẩu và các chương trình ưu đãi mới nhất.</p>
        </div>

        <div class="row g-4">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach(blog => { %>
                    <div class="col-md-4">
                        <a href="/blog/<%= blog.slug %>" class="blog-card d-block h-100">
                            <div class="blog-img-wrap">
                                <img src="<%= blog.thumbnail_url || 'https://via.placeholder.com/600x400?text=WebHoaQua+News' %>" alt="<%= blog.title %>" loading="lazy">
                                <span class="blog-tag">Tin mới</span>
                            </div>
                            <div class="blog-body">
                                <p class="blog-date">
                                    <i class="far fa-calendar me-1"></i><%= new Date(blog.created_at).toLocaleDateString('vi-VN') %>
                                    <span class="mx-2 opacity-25">|</span>
                                    <i class="far fa-user me-1"></i><%= blog.author.full_name %>
                                </p>
                                <h5 class="blog-title"><%= blog.title %></h5>
                                <p class="small text-muted mb-3 line-clamp-2"><%= blog.summary %></p>
                                <span class="blog-link">Đọc thêm <i class="fas fa-arrow-right ms-1"></i></span>
                            </div>
                        </a>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5 text-muted">
                    <i class="fas fa-newspaper fa-4x mb-3 opacity-10"></i>
                    <p>Hiện chưa có bài viết nào. Vui lòng quay lại sau!</p>
                </div>
            <% } %>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="d-flex justify-content-center mt-5">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-lg mb-0">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link rounded-circle mx-1 border-0" href="?page=<%= currentPage - 1 %>">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>
                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link rounded-circle mx-1 border-0 shadow-sm" href="?page=<%= i %>"><%= i %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link rounded-circle mx-1 border-0" href="?page=<%= currentPage + 1 %>">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        <% } %>
    </div>
</section>

<style>
    .pagination .page-link {
        width: 45px; height: 45px;
        display: flex; align-items: center; justify-content: center;
        font-weight: 600; font-size: 0.9rem;
        color: var(--brand-primary);
    }
    .pagination .page-item.active .page-link {
        background-color: var(--brand-accent);
        color: #fff;
    }
</style>
