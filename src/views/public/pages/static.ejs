<!-- ===== BREADCRUMB ===== -->
<nav class="bg-light py-3 border-bottom">
    <div class="container">
        <ol class="breadcrumb mb-0 small uppercase fw-bold" style="letter-spacing: 0.05em;">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page"><%= page.description %></li>
        </ol>
    </div>
</nav>

<section class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="bg-white p-4 p-md-5 rounded-4 shadow-sm border">
                    <h1 class="display-5 fw-bold text-primary mb-4 pb-3 border-bottom"><%= page.description %></h1>
                    
                    <div class="static-content" style="font-size: 1.1rem; line-height: 1.8; color: #1a202c;">
                        <%- page.value %>
                    </div>
                    
                    <div class="mt-5 pt-4 border-top">
                        <div class="d-flex align-items-center gap-3 text-muted small">
                            <i class="fas fa-info-circle"></i>
                            <span>Nội dung được cập nhật lần cuối vào tháng 04/2025. Cảm ơn bạn đã đồng hành cùng Hải Anh Fruit.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Advanced Typography Styles -->
<style>
    .static-content {
        font-family: var(--font-body);
        color: #334155;
    }
    .static-content h1, 
    .static-content h2, 
    .static-content h3, 
    .static-content h4 { 
        margin-top: 2.5rem; 
        margin-bottom: 1.25rem; 
        color: var(--brand-primary); 
        font-weight: 700; 
        font-family: var(--font-heading); 
        letter-spacing: -0.01em;
    }
    .static-content h1:first-child,
    .static-content h2:first-child,
    .static-content h3:first-child { margin-top: 0; }
    
    .static-content h3 { font-size: 1.75rem; }
    .static-content h4 { font-size: 1.35rem; color: var(--brand-accent); }

    .static-content p { margin-bottom: 1.5rem; font-weight: 400; }
    .static-content ul, .static-content ol { margin-bottom: 2rem; padding-left: 1.5rem; }
    .static-content li { margin-bottom: 0.75rem; }
    
    .static-content strong { color: var(--brand-primary); font-weight: 600; }
    
    .static-content img { 
        max-width: 100%; 
        height: auto; 
        border-radius: 16px; 
        margin: 2.5rem 0; 
        box-shadow: 0 20px 50px rgba(0,0,0,0.08); 
    }
    
    /* Highlight box for contact or important info */
    .static-content blockquote {
        background: var(--bg-alt);
        border-left: 4px solid var(--brand-accent);
        padding: 1.5rem 2rem;
        margin: 2rem 0;
        border-radius: 0 12px 12px 0;
        font-style: italic;
    }
</style>
