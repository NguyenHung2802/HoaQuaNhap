<style>
.section-eyebrow { color: var(--brand-accent); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
.section-title { font-family: var(--font-heading); font-size: clamp(1.8rem, 3vw, 2.5rem); color: var(--brand-primary); line-height: 1.2; }
.bg-light-grey { background: #f4f7f3; }
.section-padding { padding: 72px 0; }
.text-accent { color: var(--brand-accent); }

/* About Hero */
.about-hero-section { padding: 80px 0; background: #fff; }
.about-hero-title { font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3rem); color: var(--brand-primary); line-height: 1.15; margin-bottom: 1.2rem; }
.about-hero-desc { color: var(--text-muted); line-height: 1.8; font-size: 1.05rem; }
.about-stats { gap: 2rem; }
.about-stat-item { display: flex; flex-direction: column; }
.about-stat-number { font-size: 2rem; font-weight: 800; color: var(--brand-accent); line-height: 1; }
.about-stat-label { font-size: 0.82rem; color: var(--text-muted); margin-top: 4px; }

/* About Image Grid */
.about-img-grid { position: relative; }
.about-img-main { width: 100%; max-height: 400px; object-fit: cover; }
.about-img-secondary { position: absolute; bottom: -24px; right: -16px; width: 45%; max-height: 200px; object-fit: cover; border: 4px solid #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.12); }

/* Values */
.value-card { border-radius: 20px; padding: 32px; height: 100%; transition: transform 0.3s ease; }
.value-card:hover { transform: translateY(-5px); }
.value-icon { font-size: 2rem; color: var(--brand-primary); margin-bottom: 16px; }
.value-title { font-family: var(--font-heading); font-size: 1.2rem; color: var(--brand-primary); margin-bottom: 12px; }
.value-desc { color: var(--text-muted); font-size: 0.9rem; line-height: 1.7; margin: 0; }

/* Contact Info Card */
.contact-info-card { background: #fff; border-radius: 16px; padding: 32px 24px; border: 1px solid #eee; height: 100%; transition: all 0.3s ease; }
.contact-info-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.08); transform: translateY(-4px); }
.contact-info-icon { font-size: 1.8rem; color: var(--brand-accent); margin-bottom: 16px; }
.contact-info-card h5 { font-weight: 700; color: var(--brand-primary); margin-bottom: 12px; }

@media (max-width: 768px) {
    .about-img-secondary { display: none; }
    .about-hero-section { padding: 48px 0; }
}
</style>
