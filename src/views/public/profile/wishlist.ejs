<!-- PAGE HEADER BREADCRUMB -->
<nav class="bg-light py-3 border-bottom mb-4">
    <div class="container">
        <ol class="breadcrumb mb-0 small uppercase fw-bold" style="letter-spacing: 0.05em;">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Sản phẩm yêu thích</li>
        </ol>
    </div>
</nav>

<section class="section-padding pt-0">
    <div class="container">
        <div class="row g-4">
            <!-- SIDEBAR ACCOUNT -->
            <div class="col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-0">
                        <div class="user-sidebar-header p-4 text-center border-bottom bg-light">
                            <div class="avatar-wrapper mx-auto mb-3 position-relative">
                                <img src="<%= user.avatar_url || 'https://ui-avatars.com/api/?name=' + user.full_name + '&background=2e7d32&color=fff&size=128' %>" 
                                     alt="<%= user.full_name %>" class="rounded-circle shadow-sm object-fit-cover border border-4 border-white" style="width: 100px; height: 100px;">
                            </div>
                            <h6 class="fw-bold mb-0 text-dark text-truncate"><%= user.full_name %></h6>
                            <small class="text-muted"><%= user.email %></small>
                        </div>
                        <div class="list-group list-group-flush py-2">
                            <a href="/profile" class="list-group-item list-group-item-action border-0 px-4 py-3">
                                <i class="fas fa-user-circle me-3"></i>Thông tin cá nhân
                            </a>
                            <a href="/profile#address-book" class="list-group-item list-group-item-action border-0 px-4 py-3">
                                <i class="fas fa-map-marker-alt me-3"></i>Sổ địa chỉ
                            </a>
                            <a href="/wishlist" class="list-group-item list-group-item-action border-0 px-4 py-3 active">
                                <i class="fas fa-heart me-3"></i>Sản phẩm yêu thích
                            </a>
                            <a href="/orders" class="list-group-item list-group-item-action border-0 px-4 py-3">
                                <i class="fas fa-box me-3"></i>Lịch sử đơn hàng
                            </a>
                            <hr class="mx-3 my-1">
                            <form action="/auth/logout" method="POST">
                                <button type="submit" class="list-group-item list-group-item-action border-0 px-4 py-3 text-danger bg-transparent" style="width: 100%; border: none;">
                                    <i class="fas fa-sign-out-alt me-3"></i>Đăng xuất
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MAIN CONTENT -->
            <div class="col-lg-9">
                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                    <h4 class="fw-bold mb-4 font-serif text-brand">Sản phẩm yêu thích</h4>
                    <p class="text-muted mb-5 small">Danh sách các sản phẩm bạn đã lưu để xem lại sau.</p>
                    
                    <% if (products && products.length > 0) { %>
                        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                            <% products.forEach(p => { %>
                                <div class="col" id="wishlist-item-<%= p.id %>">
                                    <div class="fruit-card h-100 position-relative">
                                        <button class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2 z-index-1 rounded-circle shadow-sm" 
                                                style="width:32px;height:32px;padding:0;"
                                                onclick="removeFromWishlist(<%= p.id %>)" title="Xóa khỏi danh sách">
                                            <i class="fas fa-times"></i>
                                        </button>
                                        <a href="/product/<%= p.slug %>" class="text-decoration-none color-inherit">
                                            <div class="fruit-card-img-wrap">
                                                <% if (p.images && p.images.length > 0) { %>
                                                    <img src="<%= p.images[0].image_url %>" alt="<%= p.name %>" class="img-fluid">
                                                <% } else { %>
                                                    <div class="fruit-card-placeholder">🍎</div>
                                                <% } %>
                                            </div>
                                            <div class="fruit-card-body p-3">
                                                <h6 class="fruit-card-name text-dark mb-2 line-clamp-2" style="height: 2.6rem;"><%= p.name %></h6>
                                                <div class="d-flex align-items-center gap-2 mb-3">
                                                    <span class="price-main fs-5"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.bestPrice) %></span>
                                                    <% if (p.isDiscounted) { %>
                                                        <span class="small text-muted text-decoration-line-through"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.originalPrice) %></span>
                                                    <% } %>
                                                </div>
                                                <button class="btn btn-primary btn-sm w-100 rounded-pill" onclick="event.preventDefault(); addToCart(<%= p.id %>, 1)">
                                                    <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ
                                                </button>
                                            </div>
                                        </a>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-5">
                            <div class="mb-4 text-muted opacity-25">
                                <i class="fas fa-heart fa-5x"></i>
                            </div>
                            <h5>Danh sách đang trống</h5>
                            <p class="text-muted mb-4 small">Hãy khám phá các sản phẩm và nhấn "Yêu thích" để lưu vào đây.</p>
                            <a href="/products" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">Khám phá ngay</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .section-padding { padding: 60px 0; }
    .text-brand { color: #2e7d32; }
    .list-group-item.active { background-color: #2e7d32; border-color: #2e7d32; font-weight: 600; }
    .uppercase { text-transform: uppercase; letter-spacing: 0.05em; }
    .fruit-card { border: 1px solid #eee; border-radius: 18px; transition: all 0.3s; background: #fff; }
    .fruit-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
    .fruit-card-img-wrap { padding-top: 85%; position: relative; background: #f8f9fa; border-radius: 18px 18px 0 0; overflow: hidden; }
    .fruit-card-img-wrap img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .price-main { color: #d32f2f; font-weight: 800; }
    .z-index-1 { z-index: 1; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .avatar-wrapper { width: 100px; height: 100px; }
</style>

<script>
    async function removeFromWishlist(productId) {
        if (!confirm('Bạn muốn xóa sản phẩm này khỏi danh sách yêu thích?')) return;
        
        try {
            const response = await fetch(`/api/wishlist/toggle/${productId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await response.json();
            if (result.success && result.status === 'removed') {
                const item = document.getElementById('wishlist-item-' + productId);
                item.style.opacity = '0';
                item.style.transform = 'scale(0.8)';
                setTimeout(() => {
                    item.remove();
                    if (document.querySelectorAll('.col[id^="wishlist-item-"]').length === 0) {
                        window.location.reload();
                    }
                }, 300);
            }
        } catch (err) {
            console.error(err);
        }
    }
</script>
