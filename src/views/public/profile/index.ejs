<!-- PAGE HEADER BREADCRUMB -->
<nav class="bg-light py-3 border-bottom mb-4">
    <div class="container">
        <ol class="breadcrumb mb-0 small uppercase fw-bold" style="letter-spacing: 0.05em;">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Hồ sơ cá nhân</li>
        </ol>
    </div>
</nav>

<section class="section-padding pt-0">
    <div class="container">
        <div class="row g-4">
            <!-- SIDEBAR ACCOUNT -->
            <div class="col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-0">
                        <div class="user-sidebar-header p-4 text-center border-bottom bg-light">
                            <div class="avatar-wrapper mx-auto mb-3 position-relative">
                                <img src="<%= profile.avatar_url || 'https://ui-avatars.com/api/?name=' + user.full_name + '&background=2e7d32&color=fff&size=128' %>" 
                                     alt="<%= user.full_name %>" id="avatar-preview" class="rounded-circle shadow-sm object-fit-cover border border-4 border-white" style="width: 100px; height: 100px;">
                                <label for="avatar-input" class="avatar-edit-btn">
                                    <i class="fas fa-camera"></i>
                                </label>
                                <input type="file" id="avatar-input" name="avatar" accept="image/*" class="d-none">
                            </div>
                            <h6 class="fw-bold mb-0 text-dark text-truncate"><%= user.full_name %></h6>
                            <small class="text-muted"><%= user.email %></small>
                        </div>
                        <div class="list-group list-group-flush py-2">
                            <a href="#personal-info" class="list-group-item list-group-item-action border-0 px-4 py-3 active" data-bs-toggle="pill">
                                <i class="fas fa-user-circle me-3"></i>Thông tin cá nhân
                            </a>
                            <a href="#address-book" class="list-group-item list-group-item-action border-0 px-4 py-3" data-bs-toggle="pill">
                                <i class="fas fa-map-marker-alt me-3"></i>Sổ địa chỉ
                            </a>
                            <a href="/orders" class="list-group-item list-group-item-action border-0 px-4 py-3">
                                <i class="fas fa-box me-3"></i>Lịch sử đơn hàng
                            </a>
                            <hr class="mx-3 my-1">
                            <form action="/auth/logout" method="POST">
                                <button type="submit" class="list-group-item list-group-item-action border-0 px-4 py-3 text-danger bg-transparent" style="width: 100%; border: none;">
                                    <i class="fas fa-sign-out-alt me-3"></i>Đăng xuất
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MAIN CONTENT (TABS) -->
            <div class="col-lg-9">
                <div class="tab-content" id="pills-tabContent">
                    <!-- PERSONAL INFO TAB -->
                    <div class="tab-pane fade show active" id="personal-info">
                        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                            <h4 class="fw-bold mb-4 font-serif text-brand">Hồ sơ cá nhân</h4>
                            <p class="text-muted mb-5 small">Quản lý các thông tin cá nhân cơ bản để bảo mật tài khoản và thuận tiện khi mua sắm.</p>
                            
                            <form action="/profile/update" method="POST" id="profile-form">
                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted uppercase">Họ và tên</label>
                                        <input type="text" name="full_name" class="form-control rounded-pill px-3" value="<%= profile.full_name %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted uppercase">Email liên hệ</label>
                                        <input type="email" name="email" class="form-control rounded-pill px-3" value="<%= profile.email %>" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted uppercase">Số điện thoại</label>
                                        <input type="text" name="phone" class="form-control rounded-pill px-3" value="<%= profile.phone %>" required pattern="[0-9]{10}">
                                        <small class="text-muted italic px-2">Cập nhật số điện thoại liên hệ chính.</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted uppercase">Giới tính</label>
                                        <div class="d-flex gap-4 mt-2 px-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="gender" value="male" id="gMale" <%= profile.customer && profile.customer.gender === 'male' ? 'checked' : '' %>>
                                                <label class="form-check-label" for="gMale">Nam</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="gender" value="female" id="gFemale" <%= profile.customer && profile.customer.gender === 'female' ? 'checked' : '' %>>
                                                <label class="form-check-label" for="gFemale">Nữ</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="gender" value="other" id="gOther" <%= (profile.customer && profile.customer.gender === 'other') || !profile.customer || !profile.customer.gender ? 'checked' : '' %>>
                                                <label class="form-check-label" for="gOther">Khác</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted uppercase">Ngày sinh</label>
                                        <input type="date" name="birthday" class="form-control rounded-pill px-3" 
                                               value="<%= profile.customer && profile.customer.birthday ? new Date(profile.customer.birthday).toISOString().split('T')[0] : '' %>">
                                    </div>
                                    <div class="col-12 mt-5">
                                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">Lưu thay đổi</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- ADDRESS BOOK TAB -->
                    <div class="tab-pane fade" id="address-book">
                        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div>
                                    <h4 class="fw-bold mb-1 font-serif text-brand">Sổ địa chỉ</h4>
                                    <p class="text-muted small mb-0">Lưu các địa chỉ thường xuyên giao hàng.</p>
                                </div>
                                <button class="btn btn-outline-accent rounded-pill px-4 btn-sm fw-bold" data-bs-toggle="modal" data-bs-target="#modalAddress">
                                    <i class="fas fa-plus me-2"></i>Thêm mới
                                </button>
                            </div>

                            <div class="address-list mt-4">
                                <% if (profile.customer && profile.customer.addresses && profile.customer.addresses.length > 0) { %>
                                    <% profile.customer.addresses.forEach(addr => { %>
                                        <div class="address-item p-4 rounded-4 border-dashed mb-3 position-relative">
                                            <% if (addr.is_default) { %>
                                                <span class="badge bg-accent-soft text-accent position-absolute top-0 end-0 m-3 rounded-pill px-3 py-2 small">Mặc định</span>
                                            <% } %>
                                            <div class="small fw-bold text-dark mb-1 d-flex align-items-center">
                                                <%= addr.receiver_name %> 
                                                <span class="mx-2 opacity-25">|</span> 
                                                <span class="text-muted"><%= addr.receiver_phone %></span>
                                            </div>
                                            <div class="small text-muted mb-3">
                                                <%= addr.address_line %>, <%= addr.ward %>, <%= addr.district %>, <%= addr.province %>
                                            </div>
                                            <div class="d-flex gap-3">
                                                <button class="btn p-0 text-brand small fw-bold" onclick="editAddress(<%= JSON.stringify(addr) %>)">Sửa</button>
                                                <button class="btn p-0 text-danger small fw-bold" onclick="deleteAddress(<%= addr.id %>)">Xoá</button>
                                                <% if (!addr.is_default) { %>
                                                    <button class="btn p-0 text-primary small fw-bold ms-auto" onclick="setDefaultAddress(<%= addr.id %>)">Đặt mặc định</button>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="text-center py-5 text-muted opacity-50">
                                        <i class="fas fa-map-marked-alt fa-3x mb-3"></i>
                                        <p>Bạn chưa thêm địa chỉ nào.</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- MODAL ADD/EDIT ADDRESS -->
<div class="modal fade" id="modalAddress" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <form action="/profile/address/save" method="POST" id="address-form">
                <input type="hidden" name="id" id="addr-id">
                <div class="modal-header border-0 p-4 pb-0">
                    <h5 class="fw-bold font-serif text-brand" id="modalTitle">Thêm địa chỉ mới</h5>
                    <button type="button" class="btn-close" data-bs-close="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted mb-1">Người nhận</label>
                            <input type="text" name="receiver_name" id="addr-name" class="form-control rounded-3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted mb-1">SĐT nhận hàng</label>
                            <input type="text" name="receiver_phone" id="addr-phone" class="form-control rounded-3" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted mb-1">Tỉnh / Thành phố</label>
                            <select name="province" id="addr-province" class="form-select rounded-3" required>
                                <option value="">Chọn Tỉnh/Thành phố</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted mb-1">Quận / Huyện</label>
                            <select name="district" id="addr-district" class="form-select rounded-3" required>
                                <option value="">Chọn Quận/Huyện</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted mb-1">Phường / Xã</label>
                            <select name="ward" id="addr-ward" class="form-select rounded-3" required>
                                <option value="">Chọn Phường/Xã</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted mb-1">Địa chỉ chi tiết (nhà/ngõ...)</label>
                            <input type="text" name="address_line" id="addr-line" class="form-control rounded-3" required>
                        </div>
                        <div class="col-12 mt-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="is_default" value="true" id="addr-default">
                                <label class="form-check-label small" for="addr-default">Đặt làm địa chỉ mặc định</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Lưu địa chỉ</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .section-padding { padding: 60px 0; }
    .bg-accent-soft { background-color: #e8f5e9; }
    .text-accent { color: #2e7d32; }
    .btn-outline-accent { border: 2px solid #2e7d32; color: #2e7d32; }
    .btn-outline-accent:hover { background: #2e7d32; color: #fff; }
    .border-dashed { border: 1px dashed #ddd; transition: border-color 0.3s; }
    .address-item:hover { border-color: #2e7d32; }
    
    .avatar-wrapper { width: 100px; height: 100px; }
    .avatar-edit-btn {
        position: absolute; bottom: 0; right: 0;
        background: #2e7d32; color: #fff; width: 32px; height: 32px;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        cursor: pointer; border: 3px solid #fff; transition: transform 0.2s;
    }
    .avatar-edit-btn:hover { transform: scale(1.15); }
    
    .list-group-item.active { background-color: #2e7d32; border-color: #2e7d32; font-weight: 600; }
    .uppercase { text-transform: uppercase; letter-spacing: 0.05em; }
    .italic { font-style: italic; }
</style>

<script src="/js/address-helper.js"></script>
<script>
    // Initialize AddressHelper for Modal
    let addrHelper;
    document.addEventListener('DOMContentLoaded', function() {
        addrHelper = new AddressHelper({
            provinceSelector: '#addr-province',
            districtSelector: '#addr-district',
            wardSelector: '#addr-ward'
        });
    });

    // Preview Avatar before upload
    document.getElementById('avatar-input').addEventListener('change', function(e) {
        if (e.target.files && e.target.files[0]) {
            const formData = new FormData();
            formData.append('avatar', e.target.files[0]);
            
            // Show preview immediately
            const reader = new FileReader();
            reader.onload = function(ex) {
                document.getElementById('avatar-preview').src = ex.target.result;
            }
            reader.readAsDataURL(e.target.files[0]);
            
            // API Upload
            fetch('/profile/avatar-upload', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    Toastify({ text: "Cập nhật ảnh đại diện thành công!", backgroundColor: "#2e7d32" }).showToast();
                } else {
                    Toastify({ text: data.message, backgroundColor: "#e53e3e" }).showToast();
                }
            })
            .catch(err => console.error(err));
        }
    });

    function editAddress(addr) {
        document.getElementById('modalTitle').innerText = 'Chỉnh sửa địa chỉ';
        document.getElementById('addr-id').value = addr.id;
        document.getElementById('addr-name').value = addr.receiver_name;
        document.getElementById('addr-phone').value = addr.receiver_phone;
        
        // Set data-selected for dropdowns and re-init load
        const pSelect = document.getElementById('addr-province');
        const dSelect = document.getElementById('addr-district');
        const wSelect = document.getElementById('addr-ward');
        
        pSelect.dataset.selected = addr.province;
        dSelect.dataset.selected = addr.district;
        wSelect.dataset.selected = addr.ward;
        
        addrHelper.loadProvinces(); // Trigger reload with selected values
        
        document.getElementById('addr-line').value = addr.address_line;
        document.getElementById('addr-default').checked = addr.is_default;
        
        const modal = new bootstrap.Modal(document.getElementById('modalAddress'));
        modal.show();
    }

    function deleteAddress(id) {
        if(confirm('Bạn có chắc chắn muốn xoá địa chỉ này?')) {
            fetch(`/profile/address/delete/${id}`, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if(data.success) window.location.reload();
            });
        }
    }

    function setDefaultAddress(id) {
        fetch(`/profile/address/default/${id}`, { method: 'POST' })
        .then(res => res.json())
        .then(data => {
            if(data.success) window.location.reload();
        });
    }

    // Reset modal on close
    document.getElementById('modalAddress').addEventListener('hidden.bs.modal', function () {
        document.getElementById('address-form').reset();
        document.getElementById('addr-id').value = '';
        document.getElementById('modalTitle').innerText = 'Thêm địa chỉ mới';
        document.getElementById('addr-province').dataset.selected = '';
        document.getElementById('addr-district').dataset.selected = '';
        document.getElementById('addr-ward').dataset.selected = '';
    });
</script>
