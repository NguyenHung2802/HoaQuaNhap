<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Quản lý Bài viết / Tin tức</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Tin tức</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="/admin/blogs/create" class="btn btn-primary">
            <i class="fas fa-pen-nib me-2"></i>Viết bài mới
        </a>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase font-weight-bold">
                    <tr>
                        <th class="ps-4">Thumbnail</th>
                        <th>Tiêu đề & Tóm tắt</th>
                        <th>Tác giả</th>
                        <th>Ngày đăng</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (blogs && blogs.length > 0) { %>
                        <% blogs.forEach(blog => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="rounded-3 overflow-hidden border shadow-sm" style="width: 100px; height: 60px;">
                                        <img src="<%= blog.thumbnail_url || 'https://via.placeholder.com/300x180?text=No+Image' %>" alt="<%= blog.title %>" class="w-100 h-100 object-fit-cover">
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark"><%= blog.title %></div>
                                    <div class="small text-muted text-truncate" style="max-width: 300px;"><%= blog.summary || 'Không có tóm tắt' %></div>
                                    <div class="small"><code class="text-secondary">/blog/<%= blog.slug %></code></div>
                                </td>
                                <td>
                                    <span class="small text-muted"><i class="fas fa-user-edit me-1 opacity-50"></i><%= blog.author.full_name %></span>
                                </td>
                                <td>
                                    <div class="small"><%= new Date(blog.created_at).toLocaleDateString('vi-VN') %></div>
                                </td>
                                <td>
                                    <% if (blog.is_published) { %>
                                        <span class="badge bg-success bg-opacity-10 text-success border-0 px-3 py-1">Đã xuất bản</span>
                                    <% } else { %>
                                        <span class="badge bg-warning bg-opacity-10 text-warning border-0 px-3 py-1">Bản nháp</span>
                                    <% } %>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a href="/admin/blogs/edit/<%= blog.id %>" class="btn btn-sm btn-outline-primary" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger ms-1" title="Xóa" onclick="deleteBlog(<%= blog.id %>)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-newspaper fa-4x mb-3 opacity-10"></i>
                                <p class="mb-0">Chưa có bài viết nào.</p>
                                <a href="/admin/blogs/create" class="btn btn-sm btn-link mt-2">Bắt đầu viết bài đầu tiên</a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    <% if (totalPages > 1) { %>
        <div class="card-footer bg-white py-3">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm justify-content-center mb-0">
                    <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="?page=<%= currentPage - 1 %>">Trước</a>
                    </li>
                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                            <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                        </li>
                    <% } %>
                    <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                        <a class="page-link" href="?page=<%= currentPage + 1 %>">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    <% } %>
</div>

<script>
    async function deleteBlog(id) {
        if (confirm('Bạn có chắc chắn muốn xóa bài viết này không?')) {
            try {
                const response = await fetch(`/admin/blogs/${id}`, {
                    method: 'DELETE'
                });
                const result = await response.json();
                if (result.success) {
                    alert('Xóa thành công!');
                    window.location.reload();
                } else {
                    alert('Lỗi: ' + result.message);
                }
            } catch (error) {
                console.error('Delete error', error);
                alert('Có lỗi xảy ra!');
            }
        }
    }
</script>
