<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Khách Hàng Cần Tư Vấn</h1>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách yêu cầu liên hệ</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Thông tin khách</th>
                        <th>Nhu cầu</th>
                        <th>Nguồn</th>
                        <th>Ghi chú</th>
                        <th>Thời gian</th>
                        <th>Trạng thái</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (contacts && contacts.length > 0) { %>
                        <% contacts.forEach(contact => { %>
                            <tr>
                                <td>#<%= contact.id %></td>
                                <td>
                                    <div class="fw-bold"><%= contact.name %></div>
                                    <div class="text-primary"><a href="tel:<%= contact.phone %>" class="text-decoration-none"><i class="fas fa-phone-alt small"></i> <%= contact.phone %></a></div>
                                    <% if(contact.email) { %><div class="small text-muted"><i class="far fa-envelope"></i> <%= contact.email %></div><% } %>
                                </td>
                                <td><span class="badge bg-secondary"><%= contact.need %></span></td>
                                <td>
                                    <% if(contact.source_url) { %>
                                        <a href="<%= contact.source_url %>" target="_blank" class="small text-truncate d-inline-block" style="max-width: 150px;">
                                            Xem trang <i class="fas fa-external-link-alt"></i>
                                        </a>
                                    <% } else { %>
                                        <span class="text-muted small">N/A</span>
                                    <% } %>
                                </td>
                                <td><small><%= contact.note || 'Không' %></small></td>
                                <td>
                                    <small><%= new Date(contact.created_at).toLocaleString('vi-VN') %></small>
                                </td>
                                <td class="status-display">
                                    <% if(contact.status === 'new') { %>
                                        <span class="badge bg-danger">Chưa xử lý</span>
                                    <% } else if(contact.status === 'processing') { %>
                                        <span class="badge bg-warning text-dark">Đang hỗ trợ</span>
                                    <% } else { %>
                                        <span class="badge bg-success">Đã hoàn thành</span>
                                    <% } %>
                                </td>
                                <td>
                                    <select class="form-select form-select-sm status-select" data-id="<%= contact.id %>">
                                        <option value="new" <%= contact.status === 'new' ? 'selected' : '' %>>Chưa xử lý</option>
                                        <option value="processing" <%= contact.status === 'processing' ? 'selected' : '' %>>Đang hỗ trợ</option>
                                        <option value="resolved" <%= contact.status === 'resolved' ? 'selected' : '' %>>Đã hoàn thành</option>
                                    </select>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">Chưa có yêu cầu liên hệ nào.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (totalPages > 1) { %>
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="?page=<%= currentPage - 1 %>">Trước</a>
                </li>
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                        <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                    </li>
                <% } %>
                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="?page=<%= currentPage + 1 %>">Sau</a>
                </li>
            </ul>
        </nav>
        <% } %>
    </div>
</div>

<script>
document.querySelectorAll('.status-select').forEach(select => {
    select.addEventListener('change', async function() {
        const id = this.dataset.id;
        const status = this.value;
        const oldStatus = Array.from(this.options).find(opt => opt.defaultSelected).value;

        try {
            const response = await fetch(`/admin/contacts/${id}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });

            const data = await response.json();
            if (data.success) {
                // Update styling instantly
                const badge = this.closest('tr').querySelector('.status-display .badge');
                if(status === 'new') {
                    badge.className = 'badge bg-danger';
                    badge.innerText = 'Chưa xử lý';
                } else if(status === 'processing') {
                    badge.className = 'badge bg-warning text-dark';
                    badge.innerText = 'Đang hỗ trợ';
                } else {
                    badge.className = 'badge bg-success';
                    badge.innerText = 'Đã hoàn thành';
                }
                
                // Update default selected
                Array.from(this.options).forEach(opt => opt.defaultSelected = false);
                this.options[this.selectedIndex].defaultSelected = true;
                
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Đã cập nhật trạng thái',
                    showConfirmButton: false,
                    timer: 1500
                });
            } else {
                this.value = oldStatus;
                Swal.fire('Lỗi', data.message || 'Không thể cập nhật', 'error');
            }
        } catch (error) {
            this.value = oldStatus;
            Swal.fire('Lỗi', 'Đã có lỗi hệ thống', 'error');
        }
    });
});
</script>
