<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Danh sách sản phẩm</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Sản phẩm</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="/admin/products/create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Thêm sản phẩm mới
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card shadow-sm mb-4">
    <div class="card-body p-3">
        <form action="/admin/products" method="GET" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-bold">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control border-start-0" placeholder="Tên sản phẩm, SKU..." value="<%= filters.search %>">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold">Danh mục</label>
                <select name="category_id" class="form-select form-select-sm">
                    <option value="">-- Tất cả danh mục --</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>" <%= filters.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold">Trạng thái</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">-- Tất cả trạng thái --</option>
                    <option value="published" <%= filters.status == 'published' ? 'selected' : '' %>>Đang bán</option>
                    <option value="draft" <%= filters.status == 'draft' ? 'selected' : '' %>>Bản nháp</option>
                    <option value="out_of_stock" <%= filters.status == 'out_of_stock' ? 'selected' : '' %>>Hết hàng</option>
                </select>
            </div>
            <div class="col-md-2 d-grid gap-2">
                <button type="submit" class="btn btn-sm btn-primary">Lọc</button>
                <a href="/admin/products" class="btn btn-sm btn-light border text-muted">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase font-weight-bold">
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá bán</th>
                        <th>Tồn kho</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(p => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <% if (p.images && p.images.length > 0) { %>
                                                <img src="<%= p.images[0].image_url %>" alt="<%= p.name %>" class="rounded shadow-sm" style="width: 48px; height: 48px; object-fit: cover;">
                                            <% } else { %>
                                                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                                    <i class="fas fa-image text-muted opacity-25"></i>
                                                </div>
                                            <% } %>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark"><%= p.name %></div>
                                            <div class="small text-muted"><code class="text-secondary"><%= p.sku %></code></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border"><%= p.category ? p.category.name : 'N/A' %></span>
                                </td>
                                <td>
                                    <div class="fw-bold text-primary"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.price) %></div>
                                    <% if (p.sale_price) { %>
                                        <div class="small text-muted text-decoration-line-through"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p.sale_price) %></div>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (p.stock_quantity <= p.min_stock_alert) { %>
                                        <span class="text-danger fw-bold"><i class="fas fa-exclamation-triangle me-1"></i><%= p.stock_quantity %></span>
                                    <% } else { %>
                                        <span class="text-dark"><%= p.stock_quantity %></span>
                                    <% } %>
                                    <span class="small text-muted ms-1"><%= p.unit %></span>
                                </td>
                                <td>
                                    <% if (p.status === 'published') { %>
                                        <span class="badge bg-success bg-opacity-10 text-success border-0 px-2 py-1">Đang bán</span>
                                    <% } else if (p.status === 'draft') { %>
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border-0 px-2 py-1">Nháp</span>
                                    <% } else { %>
                                        <span class="badge bg-danger bg-opacity-10 text-danger border-0 px-2 py-1">Hết hàng</span>
                                    <% } %>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a href="/admin/products/edit/<%= p.id %>" class="btn btn-sm btn-outline-primary" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger ms-1" title="Xóa" onclick="deleteProduct(<%= p.id %>)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
                                <p class="mb-0">Không tìm thấy sản phẩm nào khớp với lựa chọn của bạn.</p>
                                <a href="/admin/products/create" class="btn btn-sm btn-link mt-2">Thêm ngay</a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="card-footer bg-white py-3 border-top-0">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= currentPage - 1 %>&search=<%= filters.search %>&category_id=<%= filters.category_id %>&status=<%= filters.status %>">Trước</a>
                        </li>
                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link shadow-none" href="?page=<%= i %>&search=<%= filters.search %>&category_id=<%= filters.category_id %>&status=<%= filters.status %>"><%= i %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= currentPage + 1 %>&search=<%= filters.search %>&category_id=<%= filters.category_id %>&status=<%= filters.status %>">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        <% } %>
    </div>
</div>

<script>
    async function deleteProduct(id) {
        if (confirm('Bạn có chắc chắn muốn xóa sản phẩm này không?')) {
            try {
                const response = await fetch(`/admin/products/${id}`, {
                    method: 'DELETE'
                });
                const result = await response.json();
                if (result.success) {
                    alert('Xóa thành công!');
                    window.location.reload();
                } else {
                    alert('Lỗi: ' + result.message);
                }
            } catch (error) {
                console.error('Delete error', error);
                alert('Có lỗi xảy ra!');
            }
        }
    }
</script>
