<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Sửa sản phẩm: <%= product.name %></h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/admin/products">Sản phẩm</a></li>
                <li class="breadcrumb-item active" aria-current="page">Sửa đổi</li>
            </ol>
        </nav>
    </div>
    <a href="/admin/products" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> Quay lại
    </a>
</div>

<form action="/admin/products/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">
    <div class="row">
        <!-- Main Column -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-4">Thông tin cơ bản</h5>
                    
                    <div class="mb-3">
                        <label for="name" class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="name" name="name" 
                               value="<%= product.name %>" required onkeyup="generateSlug()">
                    </div>

                    <div class="mb-3">
                        <label for="slug" class="form-label fw-bold">Slug (Đường dẫn thân thiện) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted small">/products/</span>
                            <input type="text" class="form-control" id="slug" name="slug" value="<%= product.slug %>" required>
                            <button class="btn btn-outline-secondary" type="button" onclick="generateSlug()">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="short_description" class="form-label fw-bold">Mô tả ngắn</label>
                        <textarea class="form-control" id="short_description" name="short_description" rows="2"><%= product.short_description %></textarea>
                    </div>

                    <div class="mb-0">
                        <label for="description" class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea class="form-control" id="description" name="description" rows="6"><%= product.description %></textarea>
                    </div>
                </div>
            </div>

            <!-- Pricing & Inventory -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-4">Giá & Kho hàng</h5>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="price" class="form-label fw-bold">Giá bán lẻ (VND) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="price" name="price" value="<%= product.price %>" required>
                        </div>
                        <div class="col-md-4">
                            <label for="sale_price" class="form-label fw-bold">Giá khuyến mãi (VND)</label>
                            <input type="number" class="form-control text-danger" id="sale_price" name="sale_price" value="<%= product.sale_price %>">
                        </div>
                        <div class="col-md-4">
                            <label for="cost_price" class="form-label fw-bold">Giá vốn (VND)</label>
                            <input type="number" class="form-control text-muted" id="cost_price" name="cost_price" value="<%= product.cost_price %>">
                        </div>
                        
                        <div class="col-md-4">
                            <label for="stock_quantity" class="form-label fw-bold">Số lượng tồn kho <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="stock_quantity" name="stock_quantity" value="<%= product.stock_quantity %>" required>
                        </div>
                        <div class="col-md-4">
                            <label for="min_stock_alert" class="form-label fw-bold">Cảnh báo hết hàng tại</label>
                            <input type="number" class="form-control" id="min_stock_alert" name="min_stock_alert" value="<%= product.min_stock_alert %>">
                        </div>
                        <div class="col-md-4">
                            <label for="sku" class="form-label fw-bold">Mã SKU <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="sku" name="sku" value="<%= product.sku %>" required>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Current Images & New Upload -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Hình ảnh sản phẩm</h5>
                    
                    <% if (product.images && product.images.length > 0) { %>
                        <div class="mb-4">
                            <h6>Ảnh hiện tại:</h6>
                            <div class="row g-2">
                                <% product.images.forEach(img => { %>
                                    <div class="col-auto">
                                        <div class="preview-box border rounded p-1" style="width: 100px;">
                                            <img src="<%= img.image_url %>" class="rounded" style="width: 100%; height: 80px; object-fit: cover;">
                                            <div class="form-check text-center mt-1">
                                                <input class="form-check-input" type="checkbox" name="delete_image_ids" value="<%= img.id %>" id="check-<%= img.id %>">
                                                <label class="form-check-label small text-danger" for="check-<%= img.id %>" style="font-size: 10px">Xóa</label>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>

                    <h6>Thêm ảnh mới:</h6>
                    <div id="image-previews" class="row g-2 mb-3"></div>

                    <div class="upload-zone bg-light border border-dashed rounded p-3 text-center">
                        <i class="fas fa-plus-circle fa-2x text-muted mb-1"></i>
                        <p class="small text-muted mb-2">Thêm tối đa <%= 5 - (product.images ? product.images.length : 0) %> ảnh</p>
                        <input type="file" id="file-picker" class="d-none" multiple accept="image/*" onchange="previewImages()">
                        <input type="file" name="images" id="images-input" class="d-none" multiple accept="image/*">
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="document.getElementById('file-picker').click()">Chọn tệp</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Column -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Phân loại</h5>
                    
                    <div class="mb-3">
                        <label for="category_id" class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                        <select class="form-select" id="category_id" name="category_id" required>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat.id %>" <%= product.category_id === cat.id ? 'selected' : '' %>><%= cat.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="origin_country" class="form-label fw-bold">Xuất xứ</label>
                        <input type="text" class="form-control" id="origin_country" name="origin_country" value="<%= product.origin_country %>">
                    </div>

                    <div class="row g-3 mb-0">
                        <div class="col-6">
                            <label for="unit" class="form-label fw-bold">Đơn vị</label>
                            <input type="text" class="form-control" id="unit" name="unit" value="<%= product.unit %>">
                        </div>
                        <div class="col-6">
                            <label for="weight_value" class="form-label fw-bold">Trọng lượng (kg)</label>
                            <input type="number" step="0.01" class="form-control" id="weight_value" name="weight_value" value="<%= product.weight_value %>">
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Trạng thái</h5>
                    <select class="form-select mb-3" id="status" name="status">
                        <option value="published" <%= product.status === 'published' ? 'selected' : '' %>>Đang bán</option>
                        <option value="draft" <%= product.status === 'draft' ? 'selected' : '' %>>Bản nháp</option>
                        <option value="out_of_stock" <%= product.status === 'out_of_stock' ? 'selected' : '' %>>Tạm hết hàng</option>
                    </select>

                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="is_featured" name="is_featured" value="true" <%= product.is_featured ? 'checked' : '' %>>
                        <label class="form-check-input-label fw-bold ms-2" for="is_featured">Nổi bật</label>
                    </div>

                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="is_best_seller" name="is_best_seller" value="true" <%= product.is_best_seller ? 'checked' : '' %>>
                        <label class="form-check-input-label fw-bold ms-2" for="is_best_seller">Bán chạy</label>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <button type="submit" class="btn btn-primary w-100 mb-2 py-2 fw-bold">Lưu thay đổi</button>
                    <a href="/admin/products" class="btn btn-light w-100 border">Hủy bỏ</a>
                </div>
            </div>
        </div>
    </div>
</form>

<style>
    .border-dashed { border-style: dashed !important; }
    .preview-box { position: relative; }
    .preview-box .remove-btn {
        position: absolute; top: -5px; right: -5px; background: red; color: white;
        border-radius: 50%; width: 20px; height: 20px; text-align: center;
        line-height: 18px; font-size: 12px; cursor: pointer;
    }
</style>

<script src="/js/slug-generator.js"></script>
<script>
    function generateSlug() {
        const name = document.getElementById('name').value;
        const slugInput = document.getElementById('slug');
        if (typeof slugifyVietnamese === 'function') {
            slugInput.value = slugifyVietnamese(name);
        }
    }

    const dataTransfer = new DataTransfer();
    const currentImageCount = <%= product.images ? product.images.length : 0 %>;

    function previewImages() {
        const picker = document.getElementById('file-picker');
        const hiddenInput = document.getElementById('images-input');
        if (picker.files) {
            Array.from(picker.files).forEach(file => {
                if (dataTransfer.items.length + currentImageCount < 5) {
                    dataTransfer.items.add(file);
                } else if (dataTransfer.items.length + currentImageCount >= 5) {
                    alert('Tổng số ảnh tải lên và hiện tại không được bắt quá 5 ảnh');
                }
            });
            hiddenInput.files = dataTransfer.files;
            picker.value = ''; // Reset
        }
        renderPreviews();
    }

    function renderPreviews() {
        const previewContainer = document.getElementById('image-previews');
        previewContainer.innerHTML = '';
        Array.from(dataTransfer.files).forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = (e) => {
                const div = document.createElement('div');
                div.className = 'col-auto';
                div.innerHTML = `
                    <div class="preview-box border rounded p-1 mb-2" style="width: 80px;">
                        <img src="${e.target.result}" class="rounded" style="width: 100%; height: 60px; object-fit: cover;">
                        <div class="remove-btn" onclick="removeImage(${index})"><i class="fas fa-times"></i></div>
                    </div>
                `;
                previewContainer.appendChild(div);
            }
            reader.readAsDataURL(file);
        });
    }

    function removeImage(index) {
        dataTransfer.items.remove(index);
        document.getElementById('images-input').files = dataTransfer.files;
        renderPreviews();
    }
</script>
