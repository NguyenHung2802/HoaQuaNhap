<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Chi tiết khách hàng</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/admin/customers">Khách hàng</a></li>
                <li class="breadcrumb-item active"><%= customer.full_name %></li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <a href="/admin/customers/<%= customer.id %>/edit" class="btn btn-outline-primary btn-sm">
            <i class="fas fa-edit me-1"></i>Chỉnh sửa
        </a>
        <form action="/admin/customers/<%= customer.id %>/delete" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa khách hàng này?');">
            <button type="submit" class="btn btn-outline-danger btn-sm">
                <i class="fas fa-trash me-1"></i>Xóa
            </button>
        </form>
    </div>
</div>

<div class="row g-4">
    <!-- Left: Customer Info -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 fw-bold" style="width:72px;height:72px;font-size:1.8rem;">
                    <%= customer.full_name.charAt(0).toUpperCase() %>
                </div>
                <h5 class="fw-bold mb-1"><%= customer.full_name %></h5>
                <% if (customer.user) { %>
                    <span class="badge bg-info bg-opacity-10 text-info border-0 mb-3">Tài khoản đã đăng ký</span>
                <% } else { %>
                    <span class="badge bg-secondary bg-opacity-10 text-secondary border-0 mb-3">Khách vãng lai</span>
                <% } %>

                <div class="text-start mt-3">
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted small">SĐT</span>
                        <span class="fw-bold font-monospace small"><%= customer.phone %></span>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted small">Email</span>
                        <span class="small"><%= customer.email || '—' %></span>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted small">Giới tính</span>
                        <span class="small">
                            <% if (customer.gender === 'male') { %>Nam
                            <% } else if (customer.gender === 'female') { %>Nữ
                            <% } else { %>—<% } %>
                        </span>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted small">Sinh nhật</span>
                        <span class="small"><%= customer.birthday ? new Date(customer.birthday).toLocaleDateString('vi-VN') : '—' %></span>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted small">Ngày tạo</span>
                        <span class="small"><%= new Date(customer.created_at).toLocaleDateString('vi-VN') %></span>
                    </div>
                    <% if (customer.user && customer.user.last_login_at) { %>
                        <div class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted small">Login gần nhất</span>
                            <span class="small"><%= new Date(customer.user.last_login_at).toLocaleString('vi-VN') %></span>
                        </div>
                    <% } %>
                    <% if (customer.note) { %>
                        <div class="mt-3 p-2 bg-light rounded-3">
                            <div class="small fw-bold text-muted mb-1"><i class="fas fa-sticky-note me-1"></i>Ghi chú</div>
                            <div class="small"><%= customer.note %></div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Stats -->
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="fas fa-chart-pie text-primary me-2"></i>Thống kê</h6>
                <div class="row g-2">
                    <div class="col-6">
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3 text-center">
                            <div class="fs-4 fw-bold text-primary"><%= customer.total_orders %></div>
                            <div class="small text-muted">Đơn hàng</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-success bg-opacity-10 rounded-3 p-3 text-center">
                            <div class="fs-5 fw-bold text-success"><%= new Intl.NumberFormat('vi-VN').format(customer.total_spent) %>đ</div>
                            <div class="small text-muted">Tổng chi tiêu</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Addresses -->
        <% if (customer.addresses && customer.addresses.length > 0) { %>
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="fas fa-map-marker-alt text-danger me-2"></i>Địa chỉ (<%= customer.addresses.length %>)</h6>
                    <% customer.addresses.forEach(addr => { %>
                        <div class="p-2 bg-light rounded-3 mb-2 small">
                            <div class="fw-bold">
                                <%= addr.receiver_name %> — <%= addr.receiver_phone %>
                                <% if (addr.is_default) { %><span class="badge bg-primary ms-1" style="font-size:0.6rem;">Mặc định</span><% } %>
                            </div>
                            <div class="text-muted"><%= addr.address_line %>, <%= addr.ward %>, <%= addr.district %>, <%= addr.province %></div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>
    </div>

    <!-- Right: Order History -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0 fw-bold"><i class="fas fa-shopping-cart text-primary me-2"></i>Lịch sử đơn hàng</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4">Mã đơn</th>
                                <th class="text-end">Tạm tính</th>
                                <th class="text-end">Giảm giá</th>
                                <th class="text-end">Tổng TT</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Thanh toán</th>
                                <th>Ngày đặt</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (customer.orders && customer.orders.length > 0) { %>
                                <% customer.orders.forEach(o => { %>
                                    <%
                                        const statusMap = {
                                            pending: { label: 'Chờ xác nhận', bg: 'warning' },
                                            confirmed: { label: 'Đã xác nhận', bg: 'info' },
                                            processing: { label: 'Đang xử lý', bg: 'primary' },
                                            shipping: { label: 'Đang giao', bg: 'info' },
                                            completed: { label: 'Hoàn thành', bg: 'success' },
                                            cancelled: { label: 'Đã hủy', bg: 'danger' }
                                        };
                                        const payMap = {
                                            pending: { label: 'Chưa TT', bg: 'secondary' },
                                            paid: { label: 'Đã TT', bg: 'success' },
                                            failed: { label: 'Thất bại', bg: 'danger' },
                                            refunded: { label: 'Hoàn tiền', bg: 'warning' }
                                        };
                                        const st = statusMap[o.order_status] || { label: o.order_status, bg: 'secondary' };
                                        const pt = payMap[o.payment_status] || { label: o.payment_status, bg: 'secondary' };
                                    %>
                                    <tr>
                                        <td class="ps-4">
                                            <a href="/admin/orders/<%= o.id %>" class="fw-bold text-primary text-decoration-none font-monospace small"><%= o.order_code %></a>
                                        </td>
                                        <td class="text-end small"><%= new Intl.NumberFormat('vi-VN').format(o.subtotal_amount) %>đ</td>
                                        <td class="text-end small text-danger">
                                            <% if (parseFloat(o.discount_amount) > 0) { %>
                                                -<%= new Intl.NumberFormat('vi-VN').format(o.discount_amount) %>đ
                                            <% } else { %>—<% } %>
                                        </td>
                                        <td class="text-end fw-bold small"><%= new Intl.NumberFormat('vi-VN').format(o.total_amount) %>đ</td>
                                        <td class="text-center">
                                            <span class="badge bg-<%= st.bg %> bg-opacity-10 text-<%= st.bg %> border-0 px-2 py-1" style="font-size:0.7rem;"><%= st.label %></span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-<%= pt.bg %> bg-opacity-10 text-<%= pt.bg %> border-0 px-2 py-1" style="font-size:0.7rem;"><%= pt.label %></span>
                                        </td>
                                        <td><span class="small text-muted"><%= new Date(o.created_at).toLocaleDateString('vi-VN') %></span></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">
                                        <i class="fas fa-shopping-cart fa-2x mb-2 opacity-25"></i>
                                        <p class="mb-0 small">Khách hàng chưa có đơn hàng nào.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
