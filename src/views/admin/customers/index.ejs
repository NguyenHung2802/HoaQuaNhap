<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Quản lý Khách hàng</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Khách hàng</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 text-primary rounded-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="fas fa-users fa-lg"></i>
                </div>
                <div>
                    <div class="small text-muted">Tổng khách hàng</div>
                    <div class="fs-4 fw-bold"><%= stats.totalCustomers %></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 text-success rounded-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="fas fa-user-plus fa-lg"></i>
                </div>
                <div>
                    <div class="small text-muted">Mới tháng này</div>
                    <div class="fs-4 fw-bold"><%= stats.newThisMonth %></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="small text-muted mb-2 fw-bold"><i class="fas fa-trophy text-warning me-1"></i>Top chi tiêu</div>
                <% if (stats.topSpenders && stats.topSpenders.length > 0) { %>
                    <% stats.topSpenders.slice(0, 3).forEach((s, i) => { %>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-truncate" style="max-width:140px;"><%= i+1 %>. <%= s.full_name %></span>
                            <span class="fw-bold text-nowrap"><%= new Intl.NumberFormat('vi-VN').format(s.total_spent) %>đ</span>
                        </div>
                    <% }) %>
                <% } else { %>
                    <span class="small text-muted">Chưa có dữ liệu</span>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Search -->
<div class="card shadow-sm mb-4 border-0">
    <div class="card-body p-3">
        <form action="/admin/customers" method="GET" class="row g-2 align-items-end">
            <div class="col-md-8">
                <label class="form-label small fw-bold">Tìm kiếm khách hàng</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="q" class="form-control border-start-0" placeholder="Nhập tên, SĐT hoặc email..." value="<%= search %>">
                </div>
            </div>
            <div class="col-md-4 d-grid gap-2">
                <button type="submit" class="btn btn-sm btn-primary">Tìm kiếm</button>
                <a href="/admin/customers" class="btn btn-sm btn-light border text-muted">Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- Customers Table -->
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Khách hàng</th>
                        <th>SĐT</th>
                        <th>Email</th>
                        <th class="text-center">Đơn hàng</th>
                        <th class="text-end">Tổng chi tiêu</th>
                        <th>Ngày tạo</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (customers && customers.length > 0) { %>
                        <% customers.forEach(c => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width:36px;height:36px;font-size:0.85rem;">
                                            <%= c.full_name.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <div class="fw-bold"><%= c.full_name %></div>
                                            <% if (c.user) { %>
                                                <span class="badge bg-info bg-opacity-10 text-info border-0" style="font-size:0.65rem;">Có tài khoản</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary border-0" style="font-size:0.65rem;">Khách vãng lai</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="font-monospace small"><%= c.phone %></span></td>
                                <td><span class="small text-muted"><%= c.email || '—' %></span></td>
                                <td class="text-center">
                                    <span class="badge bg-primary bg-opacity-10 text-primary border-0 px-2 py-1"><%= c.total_orders %></span>
                                </td>
                                <td class="text-end fw-bold">
                                    <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(c.total_spent) %>
                                </td>
                                <td><span class="small text-muted"><%= new Date(c.created_at).toLocaleDateString('vi-VN') %></span></td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a href="/admin/customers/<%= c.id %>" class="btn btn-sm btn-outline-primary shadow-none" title="Xem chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="/admin/customers/<%= c.id %>/edit" class="btn btn-sm btn-outline-secondary shadow-none ms-1" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fas fa-users fa-3x mb-3 opacity-25"></i>
                                <p class="mb-0">Chưa có khách hàng nào.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="card-footer bg-white py-3 border-top-0">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
                            <a class="page-link shadow-none" href="?page=<%= page - 1 %>&q=<%= search %>">Trước</a>
                        </li>
                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= page === i ? 'active' : '' %>">
                                <a class="page-link shadow-none" href="?page=<%= i %>&q=<%= search %>"><%= i %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
                            <a class="page-link shadow-none" href="?page=<%= page + 1 %>&q=<%= search %>">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        <% } %>
    </div>
</div>

<div class="text-muted small mt-3">
    Hiển thị <strong><%= customers.length %></strong> / <strong><%= total %></strong> khách hàng
</div>
