<div class="row g-4 mb-4">
    <!-- Revenue Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
            <div class="card-body p-4 bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="text-white text-opacity-75 mb-0">Doanh thu chốt</h6>
                    <i class="fas fa-money-bill-wave fa-2x text-white text-opacity-25"></i>
                </div>
                <h3 class="mb-0 fw-bold"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(stats.revenue) %></h3>
                <small>Tổng thu từ đơn đã hoàn thành</small>
            </div>
        </div>
    </div>
    <!-- Orders Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
            <div class="card-body p-4 bg-success text-white">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="text-white text-opacity-75 mb-0">Đơn hàng mới</h6>
                    <i class="fas fa-shopping-basket fa-2x text-white text-opacity-25"></i>
                </div>
                <h3 class="mb-0 fw-bold"><%= stats.pendingOrders %></h3>
                <small>Số đơn hàng đang Chờ xác nhận</small>
            </div>
        </div>
    </div>
    <!-- Products Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
            <div class="card-body p-4 bg-info text-white">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="text-white text-opacity-75 mb-0">Số lượng mặt hàng</h6>
                    <i class="fas fa-boxes fa-2x text-white text-opacity-25"></i>
                </div>
                <h3 class="mb-0 fw-bold"><%= stats.products %></h3>
                <small>Sản phẩm trong danh mục</small>
            </div>
        </div>
    </div>
    <!-- Customers Card -->
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
            <div class="card-body p-4 bg-orange text-white" style="background-color: #f6ad55!important;">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="text-white text-opacity-75 mb-0">Khách hàng</h6>
                    <i class="fas fa-users fa-2x text-white text-opacity-25"></i>
                </div>
                <h3 class="mb-0 fw-bold"><%= stats.customers %></h3>
                <small>Thành viên và khách vãng lai</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Chart -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h6 class="mb-0 fw-bold"><i class="fas fa-chart-line me-2 text-primary"></i>Doanh thu 7 ngày gần nhất</h6>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" style="min-height: 300px;"></canvas>
            </div>
        </div>
    </div>
    <!-- Low Stock Alert -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="fas fa-exclamation-triangle me-2 text-danger"></i>Cảnh báo tồn kho</h6>
                <a href="/admin/inventory" class="btn btn-sm btn-link text-decoration-none">Xem thêm</a>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <% if (lowStockProducts.length > 0) { %>
                        <% lowStockProducts.forEach(product => { %>
                            <div class="list-group-item py-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="fw-bold small text-dark"><%= product.name %></div>
                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill"><%= product.stock_quantity %> <%= product.unit %></span>
                                </div>
                                <div class="progress" style="height: 4px;">
                                    <div class="progress-bar bg-danger" style="width: <%= Math.min(100, (product.stock_quantity / product.min_stock_alert) * 100) %>%"></div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="p-4 text-center text-muted small italic">Tồn kho hiện tại rất an toàn.</div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Best Sellers -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h6 class="mb-0 fw-bold"><i class="fas fa-trophy me-2 text-warning"></i>Top 5 Sản phẩm bán chạy</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light small text-muted text-uppercase font-weight-bold">
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th class="text-center">Số lượng bán</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (bestSellers.length > 0) { %>
                                <% bestSellers.forEach((item, index) => { %>
                                    <tr>
                                        <td class="ps-4">
                                            <span class="me-2 text-muted fw-bold">#<%= index+1 %></span>
                                            <%= item.product_name_snapshot %>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark border rounded-pill px-3"><%= item._sum.quantity %></span>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="2" class="text-center py-4 text-muted small">Chưa có dữ liệu giao dịch hoàn thành.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats / Recently -->
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h6 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2 text-primary"></i>Tổng quan hệ thống</h6>
            </div>
            <div class="card-body">
                <div class="d-flex align-items-center mb-3 p-3 bg-light rounded-4">
                    <div class="flex-shrink-0 bg-white rounded-circle p-2 shadow-sm">
                        <i class="fas fa-list-ul text-primary fw-bold" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;"></i>
                    </div>
                    <div class="ms-3">
                        <div class="small text-muted">Danh mục sản phẩm</div>
                        <div class="fw-bold lh-1"><%= stats.categories %></div>
                    </div>
                </div>
                <div class="d-flex align-items-center mb-3 p-3 bg-light rounded-4">
                    <div class="flex-shrink-0 bg-white rounded-circle p-2 shadow-sm">
                        <i class="fas fa-user-plus text-success fw-bold" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;"></i>
                    </div>
                    <div class="ms-3">
                        <div class="small text-muted">Tổng số tài khoản khách</div>
                        <div class="fw-bold lh-1"><%= stats.customers %></div>
                    </div>
                </div>
                <div class="d-flex align-items-center p-3 bg-light rounded-4">
                    <div class="flex-shrink-0 bg-white rounded-circle p-2 shadow-sm">
                        <i class="fas fa-receipt text-warning fw-bold" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;"></i>
                    </div>
                    <div class="ms-3">
                        <div class="small text-muted">Tổng đơn hàng kỷ lục</div>
                        <div class="fw-bold lh-1"><%= stats.orders %></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('revenueChart').getContext('2d');
        const labels = <%- JSON.stringify(chartLabels) %>;
        const data = <%- JSON.stringify(chartData) %>;

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Doanh thu (VND)',
                    data: data,
                    borderColor: '#2d7a3a',
                    backgroundColor: 'rgba(45, 122, 58, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#2d7a3a',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { borderDash: [5, 5] },
                        ticks: {
                            callback: function(value) {
                                return new Intl.NumberFormat('vi-VN', { notation: 'compact', compactDisplay: 'short' }).format(value);
                            }
                        }
                    },
                    x: {
                        grid: { display: false }
                    }
                }
            }
        });
    });
</script>
