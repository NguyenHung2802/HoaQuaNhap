<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Chỉnh sửa: <%= page.description %></h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/admin/settings/pages">Trang tĩnh</a></li>
                <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="/admin/settings/pages" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            <i class="fas fa-arrow-left me-1"></i>Hủy
        </a>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="card-header bg-white py-3 border-bottom-0">
        <div class="d-flex align-items-center">
            <i class="fas fa-file-alt text-primary fs-3 me-3"></i>
            <div>
                <h6 class="mb-0 fw-bold"><%= page.description %></h6>
                <small class="text-muted italic">Khóa: <code class="text-primary"><%= page.key %></code></small>
            </div>
        </div>
    </div>
    <div class="card-body p-4 bg-light bg-opacity-50">
        <form id="editPageForm" action="/admin/settings/pages/edit/<%= page.key %>" method="POST">
            <div id="editor-container" style="height: 600px;" class="bg-white rounded-bottom-4 shadow-sm"></div>
            <input type="hidden" name="value" id="valueInput">
            <div class="text-end mt-4">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm fw-bold">
                    <i class="fas fa-save me-2"></i>Lưu nội dung trang
                </button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script>
    const quill = new Quill('#editor-container', {
        theme: 'snow',
        modules: {
            toolbar: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                ['link', 'image', 'video'],
                [{ 'align': [] }],
                ['clean']
            ]
        },
        placeholder: 'Bắt đầu viết nội dung trang tại đây...'
    });

    // Set initial content
    quill.root.innerHTML = `<%- page.value %>`;

    document.getElementById('editPageForm').onsubmit = function() {
        document.getElementById('valueInput').value = quill.root.innerHTML;
        return true;
    };
</script>
