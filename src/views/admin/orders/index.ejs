<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Quản lý Đơn hàng</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Đơn hàng</li>
            </ol>
        </nav>
    </div>
    <div class="text-muted small">
        Tổng số: <strong><%= totalRecords %></strong> đơn hàng
    </div>
</div>

<!-- Filters -->
<div class="card shadow-sm mb-4">
    <div class="card-body p-3">
        <form action="/admin/orders" method="GET" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-bold">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="q" class="form-control border-start-0" placeholder="Mã đơn, SĐT khách..." value="<%= filters.q %>">
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-bold">Trạng thái đơn hàng</label>
                <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>-- Tất cả trạng thái --</option>
                    <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Chờ xác nhận (Pending)</option>
                    <option value="confirmed" <%= filters.status === 'confirmed' ? 'selected' : '' %>>Đã xác nhận (Confirmed)</option>
                    <option value="processing" <%= filters.status === 'processing' ? 'selected' : '' %>>Đang xử lý (Processing)</option>
                    <option value="shipping" <%= filters.status === 'shipping' ? 'selected' : '' %>>Đang giao (Shipping)</option>
                    <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Đã hoàn thành (Completed)</option>
                    <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Đã hủy (Cancelled)</option>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary flex-grow-1">Lọc đơn hàng</button>
                <a href="/admin/orders" class="btn btn-sm btn-light border text-muted px-3">Xóa lọc</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase font-weight-bold">
                    <tr>
                        <th class="ps-4">Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (orders && orders.length > 0) { %>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark"><%= order.order_code %></div>
                                    <div class="small text-muted"><%= order.payment_method %></div>
                                </td>
                                <td>
                                    <div class="fw-semibold"><%= order.customer_name %></div>
                                    <div class="small text-muted"><i class="fas fa-phone-alt me-1"></i><%= order.customer_phone %></div>
                                </td>
                                <td>
                                    <div class="small">
                                        <%= new Date(order.created_at).toLocaleDateString('vi-VN') %><br>
                                        <span class="text-muted"><%= new Date(order.created_at).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %></span>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-accent">
                                        <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(order.total_amount) %>
                                    </div>
                                    <% if (order.payment_status === 'paid') { %>
                                        <span class="badge bg-success bg-opacity-10 text-success small pt-0" style="font-size: 0.65rem;">Đã thanh toán</span>
                                    <% } else { %>
                                        <span class="badge bg-warning bg-opacity-10 text-warning small pt-0" style="font-size: 0.65rem;">Chờ thanh toán</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% 
                                    let statusClass = 'bg-secondary';
                                    let statusText = order.order_status;
                                    switch(order.order_status) {
                                        case 'pending': statusClass = 'bg-warning text-dark'; statusText = 'Chờ xác nhận'; break;
                                        case 'confirmed': statusClass = 'bg-info text-white'; statusText = 'Đã xác nhận'; break;
                                        case 'processing': statusClass = 'bg-primary text-white'; statusText = 'Đang xử lý'; break;
                                        case 'shipping': statusClass = 'bg-info text-white'; statusText = 'Đang giao'; break;
                                        case 'completed': statusClass = 'bg-success text-white'; statusText = 'Hoàn thành'; break;
                                        case 'cancelled': statusClass = 'bg-danger text-white'; statusText = 'Đã hủy'; break;
                                    }
                                    %>
                                    <span class="badge <%= statusClass %> rounded-pill px-2 py-1" style="font-size: 0.75rem;">
                                        <%= statusText %>
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/admin/orders/<%= order.id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="fas fa-eye me-1"></i>Chi tiết
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-receipt fa-3x mb-3 opacity-25"></i>
                                <p class="mb-0">Không tìm thấy đơn hàng nào khớp với yêu cầu của bạn.</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="card-footer bg-white py-3 border-top-0">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= currentPage - 1 %>&q=<%= filters.q %>&status=<%= filters.status %>">Trước</a>
                        </li>
                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link shadow-none" href="?page=<%= i %>&q=<%= filters.q %>&status=<%= filters.status %>"><%= i %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= currentPage + 1 %>&q=<%= filters.q %>&status=<%= filters.status %>">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        <% } %>
    </div>
</div>
