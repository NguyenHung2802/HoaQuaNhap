<div class="mb-4">
    <h4 class="mb-0">Chỉnh sửa mã giảm giá: <span class="text-primary"><%= coupon.code %></span></h4>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/admin/coupons">Mã giảm giá</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa</li>
        </ol>
    </nav>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <form action="/admin/coupons/edit/<%= coupon.id %>" method="POST">
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Mã CODE <span class="text-danger">*</span></label>
                            <input type="text" name="code" class="form-control text-uppercase font-monospace fw-bold" placeholder="VD: GIAM20K" required maxlength="20" value="<%= coupon.code %>">
                            <div class="form-text small">Viết liền không dấu, độ dài tối thiểu 3 kí tự.</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Loại giảm giá <span class="text-danger">*</span></label>
                            <select name="type" class="form-select" id="coupon_type" required>
                                <option value="percent" <%= coupon.type === 'percent' ? 'selected' : '' %>>Theo phần trăm (%)</option>
                                <option value="amount" <%= coupon.type === 'amount' ? 'selected' : '' %>>Số tiền mặt (VND)</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Giá trị giảm <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" name="value" class="form-control" required min="1" step="any" value="<%= coupon.value %>">
                                <span class="input-group-text" id="value_unit"><%= coupon.type === 'percent' ? '%' : 'VND' %></span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Tổng lượt sử dụng (Tổng)</label>
                            <input type="number" name="usage_limit" class="form-control" placeholder="VD: 100" value="<%= coupon.usage_limit %>">
                        </div>
                    </div>

                    <div class="row border-top pt-4 mb-4">
                        <div class="col-md-12 mb-3">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3">Điều kiện áp dụng</h6>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Đơn hàng tối thiểu (VND)</label>
                            <div class="input-group">
                                <input type="number" name="min_order_value" class="form-control" value="<%= coupon.min_order_value %>">
                                <span class="input-group-text">VND</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3" id="max_discount_wrapper" style="<%= coupon.type === 'amount' ? 'display: none;' : '' %>">
                            <label class="form-label fw-bold small">Giảm tối đa (VND)</label>
                            <div class="input-group">
                                <input type="number" name="max_discount_value" class="form-control" value="<%= coupon.max_discount_value %>">
                                <span class="input-group-text">VND</span>
                            </div>
                            <div class="form-text small">Dùng cho loại giảm % (Để trống nếu không giới hạn).</div>
                        </div>
                    </div>

                    <div class="row border-top pt-4 mb-4">
                        <div class="col-md-12 mb-3">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3">Thời gian hiệu lực</h6>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Từ ngày</label>
                            <input type="date" name="start_at" class="form-control" value="<%= formattedDates.start_at %>">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Đến ngày</label>
                            <input type="date" name="end_at" class="form-control" value="<%= formattedDates.end_at %>">
                        </div>
                    </div>

                    <div class="row border-top pt-4 mb-4">
                        <div class="col-md-12 mb-3">
                            <h6 class="text-uppercase text-muted fw-bold small mb-3">Thông tin khác</h6>
                        </div>
                        <div class="col-md-6 mb-3">
                           <div class="form-check form-switch mt-2">
                                <input class="form-check-input shadow-none" type="checkbox" name="is_active" value="true" <%= coupon.is_active ? 'checked' : '' %> id="flexSwitchCheckDefault">
                                <label class="form-check-label fw-bold small" for="flexSwitchCheckDefault">Kích hoạt</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 shadow-sm">
                            <i class="fas fa-save me-2"></i>Lưu thay đổi
                        </button>
                        <a href="/admin/coupons" class="btn btn-light border px-4">Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('coupon_type').addEventListener('change', function() {
        const value_unit = document.getElementById('value_unit');
        const max_discount_wrapper = document.getElementById('max_discount_wrapper');
        
        if (this.value === 'amount') {
            value_unit.innerText = 'VND';
            max_discount_wrapper.style.display = 'none';
        } else {
            value_unit.innerText = '%';
            max_discount_wrapper.style.display = 'block';
        }
    });
</script>
