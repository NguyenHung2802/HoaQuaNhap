<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Quản lý mã giảm giá</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Coupons</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="/admin/coupons/create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Thêm mã mới
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card shadow-sm mb-4 border-0">
    <div class="card-body p-3">
        <form action="/admin/coupons" method="GET" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-bold">Tìm kiếm mã</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control border-start-0" placeholder="Nhập mã CODE..." value="<%= filters.search %>">
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-bold">Trạng thái</label>
                <select name="is_active" class="form-select form-select-sm">
                    <option value="">-- Tất cả trạng thái --</option>
                    <option value="true" <%= filters.is_active === 'true' ? 'selected' : '' %>>Đang kích hoạt</option>
                    <option value="false" <%= filters.is_active === 'false' ? 'selected' : '' %>>Tạm dừng</option>
                </select>
            </div>
            <div class="col-md-3 d-grid gap-2">
                <button type="submit" class="btn btn-sm btn-primary">Lọc kết quả</button>
                <a href="/admin/coupons" class="btn btn-sm btn-light border text-muted">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase font-weight-bold">
                    <tr>
                        <th class="ps-4">Mã CODE</th>
                        <th>Loại giảm giá</th>
                        <th>Giá trị</th>
                        <th>Điều kiện / Giới hạn</th>
                        <th>Hạn dùng</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (coupons && coupons.length > 0) { %>
                        <% coupons.forEach(c => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-primary font-monospace"><%= c.code %></div>
                                    <div class="small text-muted">Dùng: <span class="fw-bold"><%= c.used_count %></span> / <%= c.usage_limit || '∞' %></div>
                                </td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info border-0 px-2 py-1">
                                        <%= c.type === 'percent' ? 'Theo %' : 'Trừ tiền mặt' %>
                                    </span>
                                </td>
                                <td>
                                    <% if (c.type === 'percent') { %>
                                        <div class="fw-bold text-dark"><%= c.value %>%</div>
                                        <% if (c.max_discount_value) { %>
                                            <div class="small text-muted text-nowrap">Tối đa: <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(c.max_discount_value) %></div>
                                        <% } %>
                                    <% } else { %>
                                        <div class="fw-bold text-dark text-nowrap"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(c.value) %></div>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (c.min_order_value) { %>
                                        <div class="small"><i class="fas fa-shopping-basket me-1 opacity-50"></i>Đơn từ: <b><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(c.min_order_value) %></b></div>
                                    <% } else { %>
                                        <div class="small text-muted">Không yêu cầu đơn tối thiểu</div>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="small">
                                      <% if (c.end_at) { %>
                                        <% if (new Date(c.end_at) < new Date()) { %>
                                          <span class="text-danger fw-bold"><i class="fas fa-clock me-1"></i>Hết hạn</span>
                                        <% } else { %>
                                          <span class="text-dark"><%= new Date(c.end_at).toLocaleDateString('vi-VN') %></span>
                                        <% } %>
                                      <% } else { %>
                                        <span class="text-muted">Vô thời hạn</span>
                                      <% } %>
                                    </div>
                                </td>
                                <td>
                                    <% if (c.is_active) { %>
                                        <span class="badge bg-success bg-opacity-10 text-success border-0 px-2 py-1">Kích hoạt</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border-0 px-2 py-1">Tạm dừng</span>
                                    <% } %>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a href="/admin/coupons/edit/<%= c.id %>" class="btn btn-sm btn-outline-primary shadow-none" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger shadow-none ms-1" title="Xóa" onclick="deleteCoupon(<%= c.id %>)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fas fa-ticket-alt fa-3x mb-3 opacity-25"></i>
                                <p class="mb-0">Chưa có mã giảm giá nào được tạo.</p>
                                <a href="/admin/coupons/create" class="btn btn-sm btn-link mt-2">Tạo ngay</a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
            <div class="card-footer bg-white py-3 border-top-0">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link shadow-none" href="?page=<%= currentPage - 1 %>&search=<%= filters.search %>&is_active=<%= filters.is_active %>">Trước</a>
                        </li>
                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link shadow-none" href="?page=<%= i %>&search=<%= filters.search %>&is_active=<%= filters.is_active %>"><%= i %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link shadow-none" href="?page=<%= currentPage + 1 %>&search=<%= filters.search %>&is_active=<%= filters.is_active %>">Sau</a>
                        </li>
                    </ul>
                </nav>
            </div>
        <% } %>
    </div>
</div>

<script>
    async function deleteCoupon(id) {
        if (confirm('Bạn có chắc chắn muốn xóa mã giảm giá này không? Dữ liệu thống kê sử dụng mã có thể bị ảnh hưởng.')) {
            try {
                const response = await fetch(`/admin/coupons/${id}`, {
                    method: 'DELETE'
                });
                const result = await response.json();
                if (result.success) {
                    window.location.reload();
                } else {
                    alert('Lỗi: ' + result.message);
                }
            } catch (error) {
                console.error('Delete error', error);
                alert('Có lỗi xảy ra khi thực hiện yêu cầu!');
            }
        }
    }
</script>
