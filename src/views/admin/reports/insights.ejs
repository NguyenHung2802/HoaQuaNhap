<div class="mb-4">
    <h4 class="mb-0">Insight Khách hàng & Sản phẩm</h4>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Insights</li>
        </ol>
    </nav>
</div>

<div class="row g-4">
    <!-- Top Customers -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold text-primary"><i class="fas fa-crown me-2"></i>Top 10 Khách hàng thân thiết</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light small text-uppercase">
                            <tr>
                                <th class="ps-3 text-muted fw-bold">Khách hàng</th>
                                <th class="text-center text-muted fw-bold">Số đơn</th>
                                <th class="text-end pe-3 text-muted fw-bold">Tổng chi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (insights.topCustomers && insights.topCustomers.length > 0) { %>
                                <% insights.topCustomers.forEach(c => { %>
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-bold text-dark"><%= c.full_name %></div>
                                            <div class="small text-muted"><%= c.phone %></div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-info bg-opacity-10 text-info border-0"><%= c.total_orders %> đơn</span>
                                        </td>
                                        <td class="text-end pe-3 fw-bold text-success">
                                            <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(c.total_spent) %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted small">Chưa có dữ liệu khách hàng</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Slow Moving Products -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold text-danger"><i class="fas fa-sort-amount-down me-2"></i>Sản phẩm bán chậm (3 tháng qua)</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light small text-uppercase">
                            <tr>
                                <th class="ps-3 text-muted fw-bold">Sản phẩm</th>
                                <th class="text-center text-muted fw-bold">Đã bán</th>
                                <th class="text-end pe-3 text-muted fw-bold">Tồn kho</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (insights.slowProducts && insights.slowProducts.length > 0) { %>
                                <% insights.slowProducts.forEach(p => { %>
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-bold text-dark text-truncate" style="max-width: 200px;"><%= p.name %></div>
                                            <div class="small text-muted">SKU: <%= p.sku %></div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge <%= p.sales_count === 0 ? 'bg-danger' : 'bg-warning' %> bg-opacity-10 <%= p.sales_count === 0 ? 'text-danger' : 'text-warning' %> border-0">
                                                <%= p.sales_count %> đã bán
                                            </span>
                                        </td>
                                        <td class="text-end pe-3">
                                            <div class="fw-bold"><%= p.stock_quantity %></div>
                                            <div class="small text-muted"><%= p.category.name %></div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted small">Chưa có dữ liệu sản phẩm</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white border-top-0 py-3 small text-muted">
                <i class="fas fa-info-circle me-1"></i> Gợi ý: Hãy cân nhắc tạo <b>Mã giảm giá</b> cho các sản phẩm này để kích cầu.
            </div>
        </div>
    </div>
</div>
