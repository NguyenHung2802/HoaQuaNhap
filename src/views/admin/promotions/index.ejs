<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800"><%= title %></h1>
        <a href="/admin/promotions/create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Tạo chiến dịch mới
        </a>
    </div>

    <!-- Flash Messages -->
    <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="promotionsTable" width="100%" cellspacing="0">
                    <thead class="table-light">
                        <tr>
                            <th>Tên chiến dịch</th>
                            <th>Loại giảm</th>
                            <th>Giá trị</th>
                            <th>ĐK tối thiểu</th>
                            <th>Phạm vi</th>
                            <th>Trạng thái</th>
                            <th>Thời gian</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (promotions.length > 0) { %>
                            <% promotions.forEach(promo => { %>
                                <tr id="row-<%= promo.id %>">
                                    <td>
                                        <strong><%= promo.name %></strong>
                                        <% if (promo.description) { %>
                                            <br><small class="text-muted"><%= promo.description %></small>
                                        <% } %>
                                    </td>
                                    <td><%= promo.type === 'percent' ? 'Phần trăm (%)' : 'Số tiền (VND)' %></td>
                                    <td>
                                        <span class="fw-bold text-primary">
                                            <%= promo.type === 'percent' ? promo.value + '%' : promo.value.toLocaleString() + 'đ' %>
                                        </span>
                                    </td>
                                    <td><%= promo.min_order_value ? promo.min_order_value.toLocaleString() + 'đ' : 'Không có' %></td>
                                    <td>
                                        <% if (promo.target_type === 'all') { %>
                                            <span class="badge bg-info">Toàn sàn</span>
                                        <% } else if (promo.target_type === 'category') { %>
                                            <span class="badge bg-warning text-dark"><%= promo._count.categories %> Danh mục</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary"><%= promo._count.products %> Sản phẩm</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (promo.is_active) { %>
                                            <span class="badge bg-success">Đang bật</span>
                                        <% } else { %>
                                            <span class="badge bg-danger">Đang tắt</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <small>
                                            Bắt đầu: <%= promo.start_at ? new Date(promo.start_at).toLocaleDateString('vi-VN') : '---' %><br>
                                            Kết thúc: <%= promo.end_at ? new Date(promo.end_at).toLocaleDateString('vi-VN') : '---' %>
                                        </small>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/admin/promotions/edit/<%= promo.id %>" class="btn btn-outline-primary" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button type="button" class="btn btn-outline-danger" onclick="deletePromotion(<%= promo.id %>)" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">Chưa có chiến dịch nào được tạo.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="/admin/promotions?page=<%= currentPage - 1 %>">Trước</a>
                        </li>
                        <% for(let i = 1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link" href="/admin/promotions?page=<%= i %>"><%= i %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="/admin/promotions?page=<%= currentPage + 1 %>">Sau</a>
                        </li>
                    </ul>
                </nav>
            <% } %>
        </div>
    </div>
</div>

<script>
    async function deletePromotion(id) {
        if (!confirm('Bạn có chắc chắn muốn xóa chiến dịch này?')) return;

        try {
            const res = await fetch(`/admin/promotions/${id}`, { method: 'DELETE' });
            const result = await res.json();
            if (result.success) {
                document.getElementById(`row-${id}`).remove();
                // Optionally show a toast/alert
            } else {
                alert('Lỗi: ' + result.message);
            }
        } catch (err) {
            console.error(err);
            alert('Có lỗi xảy ra khi xóa!');
        }
    }
</script>
