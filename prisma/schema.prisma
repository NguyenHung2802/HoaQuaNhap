// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  full_name     String
  email         String   @unique
  phone         String?
  password_hash String
  role          String   @default("customer") // admin, customer, editor
  status        String   @default("active") // active, inactive, locked
  last_login_at DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  blog_posts    BlogPost[]
}

model Category {
  id            Int       @id @default(autoincrement())
  name          String
  slug          String    @unique
  description   String?
  image_url     String?
  parent_id     Int?
  sort_order    Int       @default(0)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  products      Product[]
}

model Product {
  id                Int      @id @default(autoincrement())
  name              String
  slug              String   @unique
  sku               String   @unique
  short_description String?
  description       String?
  category_id       Int
  origin_country    String?
  unit              String?  @default("kg") // kg, box, etc.
  weight_value      Float?
  packing_type      String?  // thùng, hộp, túi
  price             Decimal  @db.Decimal(10, 2)
  sale_price        Decimal? @db.Decimal(10, 2)
  cost_price        Decimal? @db.Decimal(10, 2)
  stock_quantity    Int      @default(0)
  min_stock_alert   Int      @default(5)
  status            String   @default("published") // published, draft, out_of_stock
  is_featured       Boolean  @default(false)
  is_best_seller    Boolean  @default(false)
  published_at      DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  category          Category @relation(fields: [category_id], references: [id])
  images            ProductImage[]
  tags              ProductTag[]
  cart_items        CartItem[]
  order_items       OrderItem[]
  inventory_logs    InventoryLog[]
  reviews           Review[]
}

model ProductImage {
  id           Int      @id @default(autoincrement())
  product_id   Int
  image_url    String
  public_id    String?  // From Cloudinary
  alt_text     String?
  sort_order   Int      @default(0)
  is_thumbnail Boolean  @default(false)
  created_at   DateTime @default(now())

  product      Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model ProductTag {
  id         Int     @id @default(autoincrement())
  product_id Int
  tag_name   String

  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model Customer {
  id           Int      @id @default(autoincrement())
  full_name    String
  phone        String   @unique
  email        String?  @unique
  gender       String?
  birthday     DateTime?
  note         String?
  total_orders Int      @default(0)
  total_spent  Decimal  @default(0) @db.Decimal(12, 2)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  addresses    CustomerAddress[]
  carts        Cart[]
  orders       Order[]
}

model CustomerAddress {
  id             Int      @id @default(autoincrement())
  customer_id    Int
  receiver_name  String
  receiver_phone String
  province       String
  district       String
  ward           String
  address_line   String
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  customer       Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

model Cart {
  id          Int      @id @default(autoincrement())
  session_id  String?  @unique
  customer_id Int?
  status      String   @default("active") // active, abandoned, converted
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  customer    Customer? @relation(fields: [customer_id], references: [id])
  items       CartItem[]
}

model CartItem {
  id         Int      @id @default(autoincrement())
  cart_id    Int
  product_id Int
  quantity   Int
  unit_price Decimal  @db.Decimal(10, 2)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  cart       Cart     @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model Order {
  id               Int      @id @default(autoincrement())
  order_code       String   @unique
  customer_id      Int?
  customer_name    String
  customer_phone   String
  customer_email   String?
  receiver_name    String
  receiver_phone   String
  delivery_address String
  province         String
  district         String
  ward             String
  note             String?
  subtotal_amount  Decimal  @db.Decimal(12, 2)
  shipping_fee     Decimal  @default(0) @db.Decimal(12, 2)
  discount_amount  Decimal  @default(0) @db.Decimal(12, 2)
  total_amount     Decimal  @db.Decimal(12, 2)
  payment_method   String   @default("COD")
  payment_status   String   @default("pending") // pending, paid, failed, refunded
  order_status     String   @default("pending") // pending, confirmed, processing, shipping, completed, cancelled
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  customer         Customer? @relation(fields: [customer_id], references: [id])
  items            OrderItem[]
  status_logs      OrderStatusLog[]
}

model OrderItem {
  id                    Int     @id @default(autoincrement())
  order_id              Int
  product_id            Int
  product_name_snapshot String
  sku_snapshot          String
  price_snapshot        Decimal @db.Decimal(10, 2)
  quantity              Int
  line_total            Decimal @db.Decimal(12, 2)

  order                 Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product               Product @relation(fields: [product_id], references: [id])
}

model OrderStatusLog {
  id         Int      @id @default(autoincrement())
  order_id   Int
  old_status String?
  new_status String
  note       String?
  changed_by String   @default("system")
  changed_at DateTime @default(now())

  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model InventoryLog {
  id              Int      @id @default(autoincrement())
  product_id      Int
  type            String   // import, export, adjust, order_sub, order_add
  quantity        Int
  before_quantity Int
  after_quantity  Int
  reference_type  String?  // order, manual
  reference_id    Int?     // order_id or other ref
  note            String?
  created_by      String   @default("admin")
  created_at      DateTime @default(now())

  product         Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model Banner {
  id         Int       @id @default(autoincrement())
  title      String?
  subtitle   String?
  image_url  String
  link_url   String?
  sort_order Int       @default(0)
  is_active  Boolean   @default(true)
  start_at   DateTime?
  end_at     DateTime?
}

model BlogPost {
  id            Int       @id @default(autoincrement())
  title         String
  slug          String    @unique
  summary       String?
  content       String    @db.Text
  thumbnail_url String?
  author_id     Int
  is_published  Boolean   @default(true)
  published_at  DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  author        User      @relation(fields: [author_id], references: [id])
}

model Review {
  id            Int      @id @default(autoincrement())
  product_id    Int
  customer_name String
  rating        Int      @default(5)
  content       String?
  is_approved   Boolean  @default(false)
  created_at    DateTime @default(now())

  product       Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model Coupon {
  id                  Int      @id @default(autoincrement())
  code                String   @unique
  type                String   // percent, amount
  value               Decimal  @db.Decimal(10, 2)
  min_order_value     Decimal? @db.Decimal(12, 2)
  max_discount_value  Decimal? @db.Decimal(12, 2)
  usage_limit         Int?
  used_count          Int      @default(0)
  start_at            DateTime?
  end_at              DateTime?
  is_active           Boolean  @default(true)
}

model Setting {
  id          Int     @id @default(autoincrement())
  group_key   String
  key         String  @unique
  value       String? @db.Text
  description String?
}
